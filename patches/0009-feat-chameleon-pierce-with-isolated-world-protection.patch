new file mode 100644
index 0000000000..f6ba4a11d0
--- /dev/null
+++ b/tests/e2e/test_turnstile.py
@@ -0,0 +1,129 @@
+"""E2E: Test --chameleon-pierce on real Cloudflare Turnstile (Berachain faucet)."""
+import os
+import sys
+import time
+
+sys.path.insert(0, os.path.dirname(__file__))
+from conftest import make_driver, log, screenshot, pierce_exec
+
+
+def find_turnstile_frame(driver):
+    """Find the Turnstile iframe frame ID in the CDP frame tree."""
+    tree = driver.execute_cdp_cmd('Page.getFrameTree', {})
+    result = [None]
+
+    def search(node):
+        frame = node.get('frame', {})
+        url = frame.get('url', '')
+        if 'turnstile' in url or 'challenges.cloudflare' in url:
+            result[0] = frame.get('id')
+        for child in node.get('childFrames', []):
+            search(child)
+
+    search(tree['frameTree'])
+    return result[0]
+
+
+def test_turnstile_pierce():
+    driver, seed = make_driver(pierce=True, profile_prefix="turnstile")
+    log("=== TURNSTILE PIERCE TEST ===")
+
+    # Load faucet
+    log("[1] Loading faucet...")
+    driver.get("https://bepolia.faucet.berachain.com/")
+    time.sleep(5)
+
+    # Fill wallet
+    log("[2] Filling wallet address...")
+    driver.execute_script(
+        "var i=document.querySelectorAll('input')[0];"
+        "i.focus();i.value='0x742d35Cc6634C0532925a3b844Bc9e7595f2bD18';"
+        "i.dispatchEvent(new Event('input',{bubbles:true}))"
+    )
+
+    # Wait for Turnstile (it may already be visible before submit)
+    log("[3] Waiting for Turnstile iframe...")
+    turnstile_frame_id = None
+    for i in range(30):
+        time.sleep(1)
+        turnstile_frame_id = find_turnstile_frame(driver)
+        if turnstile_frame_id:
+            log(f"  [{i+1}s] Found Turnstile frame: {turnstile_frame_id}")
+            break
+        if (i + 1) % 5 == 0:
+            log(f"  [{i+1}s] Still waiting...")
+
+    if not turnstile_frame_id:
+        log("FAIL: Turnstile frame not found after 20s")
+        screenshot(driver, "turnstile_no_frame")
+        driver.quit()
+        return False
+
+    # Pierce inside Turnstile iframe via isolated world
+    log("[4] Piercing shadow DOM inside Turnstile iframe...")
+    time.sleep(2)
+    result = pierce_exec(driver, """
+(function() {
+    var all = document.querySelectorAll('*');
+    for (var i = 0; i < all.length; i++) {
+        var sr = all[i].shadowRoot;
+        if (!sr) continue;
+        var cb = sr.querySelector("input[type='checkbox']");
+        if (cb) {
+            cb.click();
+            return 'PASS: CHECKBOX CLICKED!';
+        }
+    }
+    var bsr = document.body.shadowRoot;
+    if (bsr) {
+        var cb = bsr.querySelector("input[type='checkbox']");
+        if (cb) {
+            cb.click();
+            return 'PASS: CHECKBOX CLICKED (body shadow)!';
+        }
+        return 'FAIL: body shadow exists but no checkbox';
+    }
+    return 'FAIL: no shadow roots with checkbox found';
+})()
+""", frame_id=turnstile_frame_id)
+    log(f"  {result}")
+
+    if result and "PASS" in result:
+        log("[5] Waiting for verification...")
+        time.sleep(8)
+
+    # Check token in main frame via pierce
+    log("[6] Checking token...")
+    token = pierce_exec(driver, """
+(function() {
+    var all = document.querySelectorAll('*');
+    for (var i = 0; i < all.length; i++) {
+        var sr = all[i].shadowRoot;
+        if (!sr) continue;
+        var t = sr.querySelector("input[name='cf-turnstile-response']");
+        if (t && t.value) return t.value;
+    }
+    var t2 = document.querySelector("input[name='cf-turnstile-response']");
+    return t2 && t2.value ? t2.value : '';
+})()
+""")
+
+    if token and len(token) > 10:
+        log(f"TOKEN: {token[:60]}...")
+    else:
+        log("Token: empty")
+
+    screenshot(driver, "turnstile_result")
+    log("\nBrowser open. Ctrl+C to close.")
+    try:
+        while True:
+            time.sleep(60)
+    except KeyboardInterrupt:
+        pass
+    driver.quit()
+    return bool(token and len(token) > 10)
+
+
+if __name__ == "__main__":
+    ok = test_turnstile_pierce()
+    sys.exit(0 if ok else 1)
