diff --git a/tests/e2e/test_autoclick.py b/tests/e2e/test_autoclick.py
new file mode 100644
index 0000000000..17e65333f0
--- /dev/null
+++ b/tests/e2e/test_autoclick.py
@@ -0,0 +1,64 @@
+"""E2E: Test Chameleon auto-click on Cloudflare Turnstile (Berachain faucet)."""
+import sys
+import os
+import time
+
+sys.path.insert(0, os.path.dirname(__file__))
+from conftest import make_driver, log, screenshot, pierce_exec
+
+
+def test_autoclick():
+    driver, seed = make_driver(pierce=True, profile_prefix="autoclick")
+    log("=== TURNSTILE AUTO-CLICK TEST ===")
+
+    log("[1] Loading faucet...")
+    driver.get("https://bepolia.faucet.berachain.com/")
+    time.sleep(5)
+
+    log("[2] Filling wallet...")
+    driver.execute_script(
+        "var i=document.querySelectorAll('input')[0];"
+        "i.focus();i.value='0x742d35Cc6634C0532925a3b844Bc9e7595f2bD18';"
+        "i.dispatchEvent(new Event('input',{bubbles:true}))"
+    )
+
+    log("[3] Waiting for auto-click (up to 30s)...")
+    for i in range(30):
+        time.sleep(1)
+        # Check if token appeared (means Turnstile was solved)
+        token = pierce_exec(driver, """
+(function() {
+    var all = document.querySelectorAll('*');
+    for (var i = 0; i < all.length; i++) {
+        var sr = all[i].shadowRoot;
+        if (!sr) continue;
+        var t = sr.querySelector("input[name='cf-turnstile-response']");
+        if (t && t.value) return t.value;
+    }
+    var t2 = document.querySelector("input[name='cf-turnstile-response']");
+    return t2 && t2.value ? t2.value : '';
+})()
+""")
+        if token and len(token) > 10:
+            log(f"  [{i+1}s] TOKEN FOUND: {token[:60]}...")
+            break
+        if (i + 1) % 5 == 0:
+            log(f"  [{i+1}s] Waiting...")
+
+    if not token or len(token) <= 10:
+        log("  No token after 30s")
+
+    screenshot(driver, "autoclick_result")
+    log("\nBrowser open. Ctrl+C to close.")
+    try:
+        while True:
+            time.sleep(60)
+    except KeyboardInterrupt:
+        pass
+    driver.quit()
+    return bool(token and len(token) > 10)
+
+
+if __name__ == "__main__":
+    ok = test_autoclick()
+    sys.exit(0 if ok else 1)
