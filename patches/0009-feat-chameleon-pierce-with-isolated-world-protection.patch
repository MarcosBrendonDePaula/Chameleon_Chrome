+<script>
+// Test 1: Simple closed shadow root
+(function() {
+  var host = document.getElementById('host1');
+  var shadow = host.attachShadow({mode: 'closed'});
+  shadow.innerHTML = '<p style="color:red">I am inside a CLOSED shadow root</p>';
+
+  var sr = host.shadowRoot;
+  document.getElementById('result1').textContent = sr
+    ? 'PASS: shadowRoot accessible! Content: ' + sr.querySelector('p').textContent
+    : 'FAIL: shadowRoot is null';
+})();
+
+// Test 2: Nested closed shadows (2 levels, no iframe)
+(function() {
+  var host = document.getElementById('host2');
+  var shadow = host.attachShadow({mode: 'closed'});
+  var inner = document.createElement('div');
+  inner.id = 'inner-host';
+  shadow.appendChild(inner);
+  var shadow2 = inner.attachShadow({mode: 'closed'});
+  shadow2.innerHTML = '<p style="color:blue">I am DEEP inside 2 levels of closed shadows</p>';
+
+  var sr = host.shadowRoot;
+  if (sr) {
+    var innerHost = sr.querySelector('#inner-host');
+    var sr2 = innerHost ? innerHost.shadowRoot : null;
+    document.getElementById('result2').textContent = sr2
+      ? 'PASS: 2-level nested shadow accessible! Content: ' + sr2.querySelector('p').textContent
+      : 'FAIL: inner shadowRoot is null (level 2 failed)';
+  } else {
+    document.getElementById('result2').textContent = 'FAIL: outer shadowRoot is null (level 1 failed)';
+  }
+})();
+
+// Test 3: Turnstile-like (closed shadow > iframe > closed shadow > checkbox)
+(function() {
+  var host = document.getElementById('host3');
+  var shadow = host.attachShadow({mode: 'closed'});
+
+  var iframe = document.createElement('iframe');
+  iframe.id = 'turnstile-iframe';
+  iframe.style.cssText = 'width:300px; height:80px; border:2px solid #f90;';
+  iframe.srcdoc = '<!DOCTYPE html>' +
+    '<html><body>' +
+    '<div id="cf-wrapper"></div>' +
+    '<script>' +
+    'var w = document.getElementById("cf-wrapper");' +
+    'var s = w.attachShadow({mode: "closed"});' +
+    's.innerHTML = \'<div style="padding:10px; background:#f0f0f0; border:1px solid #ccc;">' +
+      '<label><input type="checkbox" id="turnstile-checkbox"> I am human</label>' +
+      '<p id="turnstile-status">Not verified</p></div>\';' +
+    's.querySelector("#turnstile-checkbox").addEventListener("change", function() {' +
+      's.querySelector("#turnstile-status").textContent = this.checked ? "VERIFIED!" : "Not verified";' +
+    '});' +
+    '<\/script>' +
+    '</body></html>';
+  shadow.appendChild(iframe);
+
+  iframe.onload = function() {
+    try {
+      var outerShadow = host.shadowRoot;
+      if (!outerShadow) { document.getElementById('result3').textContent = 'FAIL: outer shadowRoot is null'; return; }
+
+      var iframeEl = outerShadow.querySelector('#turnstile-iframe');
+      if (!iframeEl) { document.getElementById('result3').textContent = 'FAIL: iframe not found in shadow'; return; }
+
+      var doc = iframeEl.contentDocument;
+      if (!doc) { document.getElementById('result3').textContent = 'FAIL: iframe contentDocument is null'; return; }
+
+      var wrapper = doc.getElementById('cf-wrapper');
+      if (!wrapper) { document.getElementById('result3').textContent = 'FAIL: cf-wrapper not found in iframe'; return; }
+
+      var innerShadow = wrapper.shadowRoot;
+      if (!innerShadow) { document.getElementById('result3').textContent = 'FAIL: inner shadowRoot is null (level 2 pierce failed!)'; return; }
+
+      var checkbox = innerShadow.querySelector('#turnstile-checkbox');
+      if (!checkbox) { document.getElementById('result3').textContent = 'FAIL: checkbox not found in inner shadow'; return; }
+
+      document.getElementById('result3').textContent =
+        'PASS: Full Turnstile-like pierce works! (closed shadow > iframe > closed shadow > checkbox found)';
+
+      // Test 4: click from outside
+      checkbox.click();
+      var status = innerShadow.querySelector('#turnstile-status').textContent;
+      document.getElementById('result4').textContent = status === 'VERIFIED!'
+        ? 'PASS: Checkbox clicked and verified from outside all layers! Status: ' + status
+        : 'FAIL: Click did not work. Status: ' + status;
+    } catch(e) {
+      document.getElementById('result3').textContent = 'ERROR: ' + e.message;
+    }
+  };
+})();
+
+// Test 5: 5-level deep nested closed shadow DOM
+(function() {
+  var host = document.getElementById('host5');
+  var current = host;
+  var shadows = [];
+  for (var i = 0; i < 5; i++) {
+    var shadow = current.attachShadow({mode: 'closed'});
+    shadows.push(shadow);
+    if (i < 4) {
+      var child = document.createElement('div');
+      child.id = 'level-' + (i + 1);
+      shadow.appendChild(child);
+      current = child;
+    } else {
+      shadow.innerHTML = '<p id="deep-content" style="color:green; font-weight:bold">I am 5 levels deep in closed shadow DOM!</p>';
+    }
+  }
+
+  // Now try to access from outside
+  var node = host;
+  var ok = true;
+  for (var i = 0; i < 5; i++) {
+    var sr = node.shadowRoot;
+    if (!sr) {
+      document.getElementById('result5').textContent = 'FAIL: shadowRoot is null at level ' + (i + 1);
+      ok = false;
+      break;
+    }
+    if (i < 4) {
+      node = sr.querySelector('#level-' + (i + 1));
+      if (!node) {
+        document.getElementById('result5').textContent = 'FAIL: child not found at level ' + (i + 1);
+        ok = false;
+        break;
+      }
+    } else {
+      var content = sr.querySelector('#deep-content');
+      if (content) {
+        document.getElementById('result5').textContent = 'PASS: 5-level deep access works! Content: ' + content.textContent;
+      } else {
+        document.getElementById('result5').textContent = 'FAIL: deep content not found at level 5';
+        ok = false;
+      }
+    }
+  }
+})();
+</script>
+</body>
+</html>
