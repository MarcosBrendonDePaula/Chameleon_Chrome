+"""E2E: Test fingerprint uniqueness and suspect score on fingerprint.com."""
+import os
+import sys
+import time
+
+sys.path.insert(0, os.path.dirname(__file__))
+from conftest import make_driver, log, screenshot
+
+
+def test_fingerprint():
+    driver, seed = make_driver(profile_prefix="fingerprint")
+    log("=== FINGERPRINT TEST ===")
+    log(f"Seed: {seed}")
+
+    # Quick identity check
+    driver.get("about:blank")
+    time.sleep(1)
+    info = driver.execute_script("""
+        var c=document.createElement('canvas');var g=c.getContext('webgl');
+        var d=g.getExtension('WEBGL_debug_renderer_info');
+        return {
+            webdriver: navigator.webdriver,
+            platform: navigator.platform,
+            cores: navigator.hardwareConcurrency,
+            mem: navigator.deviceMemory,
+            lang: navigator.language,
+            gpu: d ? g.getParameter(d.UNMASKED_RENDERER_WEBGL).slice(0,55) : 'N/A'
+        };
+    """)
+    log("Identity:")
+    for k, v in info.items():
+        log(f"  {k}: {v}")
+
+    # Fingerprint.com
+    log("\nLoading fingerprint.com...")
+    driver.get("https://fingerprint.com")
+    time.sleep(20)
+
+    try:
+        result = driver.execute_script("""
+            var id = document.querySelector('.VisitsHistorySection-module--visitorId--ffa06');
+            var score = document.querySelector('.SuspectScore-module--score--31a26');
+            return {
+                visitorId: id ? id.textContent.trim() : 'not found',
+                score: score ? score.textContent.trim() : 'not found'
+            };
+        """)
+        log(f"  Visitor ID: {result['visitorId']}")
+        log(f"  Suspect Score: {result['score']}")
+    except Exception as e:
+        log(f"  Error: {e}")
+
+    screenshot(driver, "fingerprint")
+    log("\nBrowser open. Ctrl+C to close.")
+    try:
+        while True:
+            time.sleep(60)
+    except KeyboardInterrupt:
+        pass
+    driver.quit()
+
+
+if __name__ == "__main__":
+    test_fingerprint()
diff --git a/tests/e2e/test_pierce.py b/tests/e2e/test_pierce.py
new file mode 100644
index 0000000000..b34344010a
--- /dev/null
+++ b/tests/e2e/test_pierce.py
@@ -0,0 +1,143 @@
+"""E2E: Test --chameleon-pierce shadow DOM access.
+
+Pierce only works in isolated worlds (CDP/DevTools), not in the main world.
+This ensures fingerprinting scripts cannot detect the bypass.
+"""
+import os
+import sys
+import time
+
+sys.path.insert(0, os.path.dirname(__file__))
+from conftest import make_driver, log, screenshot, pierce_exec
+
+FIXTURE = os.path.join(os.path.dirname(__file__), "fixtures", "pierce_test.html")
+
+
+def test_pierce():
+    driver, seed = make_driver(pierce=True, profile_prefix="pierce")
+    log("=== PIERCE TEST (isolated world vs main world) ===\n")
+
+    driver.get(f"file:///{FIXTURE.replace(os.sep, '/')}")
+    time.sleep(3)
+
+    passed = 0
+    total = 0
+
+    # --- Main world tests (page JS) - pierce must NOT work ---
+    log("--- Main world (page JS) - must NOT pierce ---")
+    for i in range(1, 6):
+        r = driver.execute_script(f"return document.getElementById('result{i}').textContent")
+        # "FAIL" or "Waiting..." both mean page JS couldn't pierce (correct behavior)
+        is_blocked = r.startswith("FAIL") or r == "Waiting..."
+        total += 1
+        if is_blocked:
+            passed += 1
+        log(f"  [{'OK' if is_blocked else 'BAD'}] Test {i}: {r}")
+
+    # --- Main world via execute_script - pierce must NOT work ---
+    log("\n--- Main world (Selenium execute_script) - must NOT pierce ---")
+    r = driver.execute_script("""
+        var host = document.getElementById('host1');
+        var sr = host.shadowRoot;
+        return sr ? 'LEAKED: shadowRoot visible in main world!' : 'OK: shadowRoot is null';
+    """)
+    total += 1
+    if r.startswith("OK"):
+        passed += 1
+    log(f"  [{'OK' if r.startswith('OK') else 'BAD'}] {r}")
+
+    # --- Isolated world (CDP) - pierce MUST work ---
+    log("\n--- Isolated world (CDP) - must pierce ---")
+
+    # Test: closed shadow root access
+    r = pierce_exec(driver, """
+        (function() {
+            var host = document.getElementById('host1');
+            var sr = host.shadowRoot;
+            if (!sr) return 'FAIL: shadowRoot is null';
+            var p = sr.querySelector('p');
+            return p ? 'PASS: ' + p.textContent : 'FAIL: no content';
+        })()
+    """)
+    total += 1
+    ok = r and r.startswith("PASS")
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] Closed shadow: {r}")
+
+    # Test: 2-level nested closed shadow
+    r = pierce_exec(driver, """
+        (function() {
+            var host = document.getElementById('host2');
+            var sr = host.shadowRoot;
+            if (!sr) return 'FAIL: outer shadowRoot is null';
+            var inner = sr.querySelector('#inner-host');
+            if (!inner) return 'FAIL: inner host not found';
+            var sr2 = inner.shadowRoot;
+            if (!sr2) return 'FAIL: inner shadowRoot is null';
+            var p = sr2.querySelector('p');
+            return p ? 'PASS: ' + p.textContent : 'FAIL: no content';
+        })()
+    """)
+    total += 1
+    ok = r and r.startswith("PASS")
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] 2-level nested: {r}")
+
+    # Test: Turnstile-like (shadow > iframe > shadow > checkbox)
+    r = pierce_exec(driver, """
+        (function() {
+            var host = document.getElementById('host3');
+            var sr = host.shadowRoot;
+            if (!sr) return 'FAIL: outer shadowRoot is null';
+            var iframe = sr.querySelector('#turnstile-iframe');
+            if (!iframe) return 'FAIL: iframe not found';
+            var doc = iframe.contentDocument;
+            if (!doc) return 'FAIL: contentDocument is null';
+            var wrapper = doc.getElementById('cf-wrapper');
+            if (!wrapper) return 'FAIL: cf-wrapper not found';
+            var innerSr = wrapper.shadowRoot;
+            if (!innerSr) return 'FAIL: inner shadowRoot is null';
+            var cb = innerSr.querySelector('#turnstile-checkbox');
+            if (!cb) return 'FAIL: checkbox not found';
+            cb.click();
+            var status = innerSr.querySelector('#turnstile-status').textContent;
+            return status === 'VERIFIED!' ? 'PASS: Turnstile-like pierce + click works!' : 'FAIL: ' + status;
+        })()
+    """)
+    total += 1
+    ok = r and r.startswith("PASS")
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] Turnstile-like: {r}")
+
+    # Test: 5-level deep
+    r = pierce_exec(driver, """
+        (function() {
+            var node = document.getElementById('host5');
+            for (var i = 0; i < 5; i++) {
+                var sr = node.shadowRoot;
+                if (!sr) return 'FAIL: shadowRoot null at level ' + (i+1);
+                if (i < 4) {
+                    node = sr.querySelector('#level-' + (i+1));
+                    if (!node) return 'FAIL: child not found at level ' + (i+1);
+                } else {
+                    var p = sr.querySelector('#deep-content');
+                    return p ? 'PASS: 5-level deep! ' + p.textContent : 'FAIL: content not found';
+                }
+            }
+        })()
+    """)
+    total += 1
+    ok = r and r.startswith("PASS")
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] 5-level deep: {r}")
+
+    screenshot(driver, "pierce")
+    driver.quit()
+
+    log(f"\n=== Results: {passed}/{total} passed ===")
+    return passed == total
+
+
+if __name__ == "__main__":
+    ok = test_pierce()
+    sys.exit(0 if ok else 1)
