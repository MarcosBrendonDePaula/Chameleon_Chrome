+++ b/tests/e2e/conftest.py
@@ -0,0 +1,85 @@
+"""Shared helpers for Chameleon E2E tests."""
+import random
+import os
+from selenium import webdriver
+from selenium.webdriver.chrome.options import Options
+from selenium.webdriver.chrome.service import Service
+
+CHROME_BIN = "E:\\CHAMALEON\\out\\Default\\chrome.exe"
+CHROMEDRIVER = "E:\\CHAMALEON\\out\\Default\\chromedriver.exe"
+PROFILES_DIR = "E:\\chameleon_profiles"
+SCREENSHOTS_DIR = os.path.join(os.path.dirname(__file__), "screenshots")
+
+
+def log(msg):
+    print(msg, flush=True)
+
+
+def random_seed():
+    return ''.join(random.choices('0123456789abcdef', k=32))
+
+
+def make_driver(seed=None, pierce=False, locale="en-US,en", modules=None, profile_prefix="e2e"):
+    """Create a Chameleon Chrome driver with the given options."""
+    if seed is None:
+        seed = random_seed()
+
+    profile_dir = os.path.join(
+        PROFILES_DIR,
+        f"{profile_prefix}_{''.join(random.choices('abcdef', k=4))}"
+    )
+
+    options = Options()
+    options.binary_location = CHROME_BIN
+    options.add_argument(f"--user-data-dir={profile_dir}")
+    options.add_argument(f"--chameleon-seed={seed}")
+    options.add_argument(f"--chameleon-locale={locale}")
+
+    if pierce:
+        options.add_argument("--chameleon-pierce")
+    if modules:
+        options.add_argument(f"--chameleon-modules={modules}")
+
+    service = Service(CHROMEDRIVER)
+    driver = webdriver.Chrome(service=service, options=options)
+    return driver, seed
+
+
+def screenshot(driver, name):
+    """Save screenshot to the screenshots dir."""
+    os.makedirs(SCREENSHOTS_DIR, exist_ok=True)
+    path = os.path.join(SCREENSHOTS_DIR, f"{name}.png")
+    driver.save_screenshot(path)
+    log(f"Screenshot: {path}")
+
+
+def _get_isolated_context(driver, frame_id=None):
+    """Create or reuse an isolated world context for the given frame."""
+    if frame_id is None:
+        tree = driver.execute_cdp_cmd('Page.getFrameTree', {})
+        frame_id = tree['frameTree']['frame']['id']
+    result = driver.execute_cdp_cmd('Page.createIsolatedWorld', {
+        'frameId': frame_id,
+        'worldName': 'chameleon_pierce',
+        'grantUniveralAccess': True,
+    })
+    return result['executionContextId']
+
+
+def pierce_exec(driver, script, frame_id=None):
+    """Execute JS in an isolated world (where --chameleon-pierce works).
+
+    Unlike driver.execute_script() which runs in the main world,
+    this runs via CDP in an isolated world so closed shadow roots
+    and cross-origin iframes are accessible.
+    """
+    ctx_id = _get_isolated_context(driver, frame_id)
+    result = driver.execute_cdp_cmd('Runtime.evaluate', {
+        'expression': script,
+        'contextId': ctx_id,
+        'returnByValue': True,
+        'awaitPromise': False,
+    })
+    if 'exceptionDetails' in result:
+        raise RuntimeError(result['exceptionDetails']['text'])
+    return result['result'].get('value')
