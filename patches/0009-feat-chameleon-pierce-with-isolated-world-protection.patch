diff --git a/third_party/blink/renderer/core/chameleon/chameleon_autoclick.cc b/third_party/blink/renderer/core/chameleon/chameleon_autoclick.cc
new file mode 100644
index 0000000000..7eb680ef7e
--- /dev/null
+++ b/third_party/blink/renderer/core/chameleon/chameleon_autoclick.cc
@@ -0,0 +1,125 @@
+// Copyright 2025 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "third_party/blink/renderer/core/chameleon/chameleon_autoclick.h"
+
+#include <string>
+
+#include "base/command_line.h"
+#include "base/functional/bind.h"
+#include "base/task/single_thread_task_runner.h"
+#include "third_party/blink/renderer/core/dom/document.h"
+#include "third_party/blink/renderer/core/dom/element.h"
+#include "third_party/blink/renderer/core/dom/events/simulated_click_options.h"
+#include "third_party/blink/renderer/core/dom/shadow_root.h"
+#include "third_party/blink/renderer/core/dom/static_node_list.h"
+#include "third_party/blink/renderer/core/frame/local_frame.h"
+#include "third_party/blink/renderer/core/html/html_body_element.h"
+#include "third_party/blink/renderer/platform/bindings/exception_state.h"
+#include "third_party/blink/renderer/platform/heap/persistent.h"
+#include "third_party/blink/renderer/platform/wtf/functional.h"
+#include "third_party/blink/renderer/platform/wtf/text/atomic_string.h"
+
+namespace blink {
+
+// static
+bool ChameleonAutoClick::IsPierceEnabled() {
+  static bool checked = false;
+  static bool enabled = false;
+  if (!checked) {
+    checked = true;
+    if (base::CommandLine::InitializedForCurrentProcess()) {
+      enabled = base::CommandLine::ForCurrentProcess()->HasSwitch(
+          "chameleon-pierce");
+    }
+  }
+  return enabled;
+}
+
+// static
+void ChameleonAutoClick::OnDocumentLoad(Document& document) {
+  if (!IsPierceEnabled())
+    return;
+
+  // Check if this document's URL is a Turnstile challenge.
+  std::string url = document.Url().GetString().Utf8();
+  if (url.find("challenges.cloudflare.com") == std::string::npos ||
+      url.find("turnstile") == std::string::npos) {
+    return;
+  }
+
+  // Start trying to find and click the checkbox.
+  // The shadow DOM inside the Turnstile iframe may not be ready immediately,
+  // so we retry a few times with a delay.
+  TryClickCheckbox(&document, /*retries=*/20);
+}
+
+// static
+void ChameleonAutoClick::TryClickCheckbox(Document* document, int retries) {
+  if (!document || retries <= 0)
+    return;
+
+  // The Turnstile structure is:
+  //   <body>
+  //     #shadow-root (closed)
+  //       <div>
+  //         <input type="checkbox">
+
+  Element* body = document->body();
+  if (!body)
+    goto retry;
+
+  {
+    // Check body's shadow root first (Turnstile attaches to body).
+    ShadowRoot* shadow = body->GetShadowRoot();
+    if (shadow) {
+      DummyExceptionStateForTesting exception_state;
+      Element* checkbox = shadow->querySelector(
+          AtomicString("input[type='checkbox']"), exception_state);
+      if (checkbox) {
+        checkbox->DispatchSimulatedClick(
+            nullptr, SimulatedClickCreationScope::kFromUserAgent);
+        return;  // Done!
+      }
+    }
+
+    // Also search all elements for shadow roots with checkboxes.
+    {
+      DummyExceptionStateForTesting exception_state;
+      StaticElementList* elements = document->querySelectorAll(
+          AtomicString("*"), exception_state);
+      if (elements) {
+        for (unsigned i = 0; i < elements->length(); i++) {
+          Element* el = elements->item(i);
+          ShadowRoot* sr = el->GetShadowRoot();
+          if (!sr)
+            continue;
+          DummyExceptionStateForTesting inner_exception;
+          Element* cb = sr->querySelector(
+              AtomicString("input[type='checkbox']"), inner_exception);
+          if (cb) {
+            cb->DispatchSimulatedClick(
+                nullptr, SimulatedClickCreationScope::kFromUserAgent);
+            return;  // Done!
+          }
+        }
+      }
+    }
+  }
+
+retry:
+  // Retry after 500ms.
+  LocalFrame* frame = document->GetFrame();
+  if (!frame)
+    return;
+
+  frame->GetTaskRunner(TaskType::kInternalDefault)
+      ->PostDelayedTask(
+          FROM_HERE,
+          BindOnce(&ChameleonAutoClick::TryClickCheckbox,
+                        WrapPersistent(document), retries - 1),
+          base::Milliseconds(500));
+}
+
+}  // namespace blink
diff --git a/third_party/blink/renderer/core/chameleon/chameleon_autoclick.h b/third_party/blink/renderer/core/chameleon/chameleon_autoclick.h
