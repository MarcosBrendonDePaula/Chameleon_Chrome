--- /dev/null
+++ b/third_party/blink/renderer/core/chameleon/chameleon_autoclick.h
@@ -0,0 +1,34 @@
+// Copyright 2025 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef THIRD_PARTY_BLINK_RENDERER_CORE_CHAMELEON_CHAMELEON_AUTOCLICK_H_
+#define THIRD_PARTY_BLINK_RENDERER_CORE_CHAMELEON_CHAMELEON_AUTOCLICK_H_
+
+#include "third_party/blink/renderer/core/core_export.h"
+
+namespace blink {
+
+class Document;
+
+// Chameleon auto-click for Cloudflare Turnstile.
+// When --chameleon-pierce is active and a Turnstile iframe finishes loading,
+// this finds the checkbox inside the closed shadow DOM and clicks it
+// automatically using DispatchSimulatedClick (UserAgent level).
+//
+// This runs entirely inside the iframe's renderer process, so no cross-origin
+// access is needed and nothing is exposed to page JS.
+class CORE_EXPORT ChameleonAutoClick {
+ public:
+  // Called when a document finishes loading. Checks if it's a Turnstile
+  // iframe and schedules auto-click if so.
+  static void OnDocumentLoad(Document& document);
+
+ private:
+  static bool IsPierceEnabled();
+  static void TryClickCheckbox(Document* document, int retries);
