From 87f347a75cdc7b181e450b1ba718480d35c276fe Mon Sep 17 00:00:00 2001
From: Marcos <marcosbrendonaz@gmail.com>
Date: Fri, 27 Mar 2026 03:38:48 -0300
Subject: [PATCH 16/17] feat: auto-generate per-profile chameleon seed

Each Chrome profile (Default, Profile 1, Profile 2...) now automatically
generates and persists its own 128-bit crypto-random seed in
chameleon_seed.txt. If --chameleon-seed is passed via CLI, it takes
precedence. Otherwise the per-profile seed is used.

Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>
---
 .../renderer_host/render_process_host_impl.cc | 30 +++++++++++++++++++
 1 file changed, 30 insertions(+)

diff --git a/content/browser/renderer_host/render_process_host_impl.cc b/content/browser/renderer_host/render_process_host_impl.cc
index 10f0b39801683..1de02e89d7401 100644
--- a/content/browser/renderer_host/render_process_host_impl.cc
+++ b/content/browser/renderer_host/render_process_host_impl.cc
@@ -29,6 +29,7 @@
 #include "base/feature_list.h"
 #include "base/files/file.h"
 #include "base/files/file_util.h"
+#include "base/strings/string_number_conversions.h"
 #include "base/functional/bind.h"
 #include "base/functional/callback.h"
 #include "base/location.h"
@@ -3604,6 +3605,35 @@ void RenderProcessHostImpl::AppendRendererCommandLine(
       *base::CommandLine::ForCurrentProcess();
   PropagateBrowserCommandLineToRenderer(browser_command_line, command_line);
 
+  // Chameleon: per-profile seed. If no --chameleon-seed was passed via command
+  // line, read or generate one from the profile directory. Each Chrome profile
+  // (Default, Profile 1, Profile 2...) gets its own persistent seed.
+  if (!command_line->HasSwitch(blink::switches::kChameleonSeed)) {
+    base::FilePath profile_path =
+        GetBrowserContext()->GetPath();
+    base::FilePath seed_file =
+        profile_path.AppendASCII("chameleon_seed.txt");
+
+    std::string seed_hex;
+    if (base::ReadFileToString(seed_file, &seed_hex)) {
+      // Trim whitespace/newlines
+      seed_hex.erase(seed_hex.find_last_not_of(" \t\n\r") + 1);
+      seed_hex.erase(0, seed_hex.find_first_not_of(" \t\n\r"));
+    }
+
+    if (seed_hex.empty() || seed_hex.length() < 16) {
+      // Generate new 128-bit crypto-random seed
+      uint8_t bytes[16];
+      base::RandBytes(bytes);
+      seed_hex = base::HexEncode(bytes);
+      // Save to profile directory
+      base::WriteFile(seed_file, seed_hex);
+    }
+
+    command_line->AppendSwitchASCII(
+        blink::switches::kChameleonSeed, seed_hex);
+  }
+
   // Pass on the browser locale.
   const std::string locale =
       GetContentClient()->browser()->GetApplicationLocale();
-- 
