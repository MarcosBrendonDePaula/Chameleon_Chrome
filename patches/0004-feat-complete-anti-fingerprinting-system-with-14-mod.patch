+namespace blink {
+
+// Chameleon anti-fingerprinting noise system.
+// Reads a seed from --chameleon-seed command line flag and provides
+// deterministic pseudo-random values for various fingerprinting surfaces.
+// Each subsystem gets a unique noise stream derived from the seed.
+//
+// Module control via --chameleon-modules=canvas,webgl,audio,...
+// If --chameleon-modules is omitted, all modules are active.
+// Use --chameleon-modules=none to disable all modules.
+class CORE_EXPORT ChameleonNoise {
+ public:
+  // Returns true if --chameleon-seed was provided.
+  static bool IsEnabled();
+
+  // Returns true if the specific module is enabled.
+  // Checks both --chameleon-seed and --chameleon-modules.
+  static bool IsModuleEnabled(uint32_t subsystem_id);
+
+  // Returns the raw 64-bit seed (parsed from hex).
+  static uint64_t GetSeed();
+
+  // Returns a deterministic double in [0, 1) for a given subsystem ID.
+  static double GetNoiseValue(uint32_t subsystem_id);
+
+  // Returns a deterministic int in [0, max_value) for a given subsystem ID.
+  static int GetNoiseInt(uint32_t subsystem_id, int max_value);
+
+  // Subsystem IDs for different fingerprinting surfaces.
+  static constexpr uint32_t kSubsystemCanvas = 1;
+  static constexpr uint32_t kSubsystemWebGL = 2;
+  static constexpr uint32_t kSubsystemAudio = 3;
+  static constexpr uint32_t kSubsystemWebRTC = 4;
+  static constexpr uint32_t kSubsystemDeviceMemory = 5;
+  static constexpr uint32_t kSubsystemClientRects = 6;
+  static constexpr uint32_t kSubsystemScreen = 7;
+  static constexpr uint32_t kSubsystemLocale = 8;
+  static constexpr uint32_t kSubsystemFonts = 9;
+  static constexpr uint32_t kSubsystemMath = 10;
+  static constexpr uint32_t kSubsystemWebGLRenderer = 11;
+  static constexpr uint32_t kSubsystemNavigator = 12;
+  static constexpr uint32_t kSubsystemWebGLParams = 13;
+
+ private:
+  static void EnsureInitialized();
+
+  static bool initialized_;
+  static bool enabled_;
+  static uint64_t seed_;
+
+  // Bitmask of enabled modules. Bit N = subsystem ID N.
+  // 0xFFFFFFFF means all modules active (default).
+  static uint32_t enabled_modules_;
+};
+
+// Hardware profile accessors - returns values from the seed-selected
+// hardware identity (OS + GPU + cores + RAM). Defined in navigator_base.cc.
+CORE_EXPORT const char* ChameleonGetGpuVendor();
+CORE_EXPORT const char* ChameleonGetGpuRenderer();
+CORE_EXPORT unsigned ChameleonGetCores();
+CORE_EXPORT float ChameleonGetMemory();
+CORE_EXPORT int ChameleonGetMaxTextureSize();
+
+}  // namespace blink
