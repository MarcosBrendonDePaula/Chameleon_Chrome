+uint64_t ChameleonFontHash(uint64_t seed, const std::string& font_name) {
+  uint64_t hash = seed ^ kFnvOffset;
+  for (char c : font_name) {
+    hash ^= static_cast<uint64_t>(c);
+    hash *= kFnvPrime;
+  }
+  return hash;
