+// found in the LICENSE file.
+
+#include "third_party/blink/renderer/core/chameleon/chameleon_noise.h"
+
+#include <cstdlib>
+#include <string>
+
+#include "base/command_line.h"
+#include "base/strings/string_split.h"
+#include "third_party/blink/public/common/switches.h"
+
+namespace blink {
+
+// FNV-1a constants (same as canvas_interventions/noise_hash.cc)
+namespace {
+constexpr uint64_t kFnvOffset = 0xcbf29ce484222325ULL;
+constexpr uint64_t kFnvPrime = 0x00000100000001b3ULL;
+
+uint64_t FnvHash(uint64_t seed, uint64_t value) {
+  uint64_t hash = seed ^ kFnvOffset;
+  for (int i = 0; i < 8; ++i) {
+    hash ^= (value >> (i * 8)) & 0xFF;
+    hash *= kFnvPrime;
+  }
+  return hash;
+}
+
+// Map module name string to subsystem bitmask.
+uint32_t ModuleNameToBit(const std::string& name) {
+  if (name == "canvas") return 1u << ChameleonNoise::kSubsystemCanvas;
+  if (name == "webgl") return (1u << ChameleonNoise::kSubsystemWebGL) |
+                              (1u << ChameleonNoise::kSubsystemWebGLRenderer);
+  if (name == "audio") return 1u << ChameleonNoise::kSubsystemAudio;
+  if (name == "webrtc") return 1u << ChameleonNoise::kSubsystemWebRTC;
+  if (name == "memory") return 1u << ChameleonNoise::kSubsystemDeviceMemory;
+  if (name == "rects") return 1u << ChameleonNoise::kSubsystemClientRects;
+  if (name == "screen") return 1u << ChameleonNoise::kSubsystemScreen;
+  if (name == "locale") return 1u << ChameleonNoise::kSubsystemLocale;
+  if (name == "fonts") return 1u << ChameleonNoise::kSubsystemFonts;
+  if (name == "math") return 1u << ChameleonNoise::kSubsystemMath;
+  if (name == "navigator") return 1u << ChameleonNoise::kSubsystemNavigator;
+  if (name == "webglparams") return 1u << ChameleonNoise::kSubsystemWebGLParams;
+  return 0;
+}
+}  // namespace
+
+bool ChameleonNoise::initialized_ = false;
+bool ChameleonNoise::enabled_ = false;
+uint64_t ChameleonNoise::seed_ = 0;
+uint32_t ChameleonNoise::enabled_modules_ = 0xFFFFFFFF;
+
+void ChameleonNoise::EnsureInitialized() {
+  if (initialized_) {
+    return;
+  }
+
+  // Guard against being called before CommandLine is initialized.
+  if (!base::CommandLine::InitializedForCurrentProcess()) {
+    return;
+  }
+
+  initialized_ = true;
+
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line->HasSwitch(switches::kChameleonSeed)) {
+    enabled_ = false;
+    return;
+  }
+
+  std::string seed_hex =
+      command_line->GetSwitchValueASCII(switches::kChameleonSeed);
+  if (seed_hex.empty()) {
+    enabled_ = false;
+    return;
+  }
+
+  // Parse hex string to uint64_t (take first 16 hex chars = 64 bits)
+  seed_ = 0;
+  for (size_t i = 0; i < seed_hex.size() && i < 16; ++i) {
+    char c = seed_hex[i];
+    uint64_t nibble = 0;
+    if (c >= '0' && c <= '9') {
+      nibble = c - '0';
+    } else if (c >= 'a' && c <= 'f') {
+      nibble = c - 'a' + 10;
+    } else if (c >= 'A' && c <= 'F') {
+      nibble = c - 'A' + 10;
+    }
+    seed_ = (seed_ << 4) | nibble;
+  }
+
+  enabled_ = (seed_ != 0);
+
+  // Parse --chameleon-modules if present.
+  if (command_line->HasSwitch(switches::kChameleonModules)) {
+    std::string modules_str =
+        command_line->GetSwitchValueASCII(switches::kChameleonModules);
+    if (modules_str == "none") {
+      enabled_modules_ = 0;
+    } else if (modules_str == "all" || modules_str.empty()) {
+      enabled_modules_ = 0xFFFFFFFF;
+    } else {
+      enabled_modules_ = 0;
+      std::vector<std::string> parts = base::SplitString(
+          modules_str, ",", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY);
+      for (const auto& part : parts) {
+        enabled_modules_ |= ModuleNameToBit(part);
+      }
+    }
+  }
+  // If --chameleon-modules is not set, enabled_modules_ stays 0xFFFFFFFF (all).
+}
+
+bool ChameleonNoise::IsEnabled() {
+  EnsureInitialized();
+  return enabled_;
+}
+
+bool ChameleonNoise::IsModuleEnabled(uint32_t subsystem_id) {
+  EnsureInitialized();
+  if (!enabled_) {
+    return false;
+  }
+  return (enabled_modules_ & (1u << subsystem_id)) != 0;
+}
+
+uint64_t ChameleonNoise::GetSeed() {
+  EnsureInitialized();
+  return seed_;
+}
+
+double ChameleonNoise::GetNoiseValue(uint32_t subsystem_id) {
+  EnsureInitialized();
+  uint64_t hash = FnvHash(seed_, static_cast<uint64_t>(subsystem_id));
+  return static_cast<double>(hash) / static_cast<double>(UINT64_MAX);
+}
+
+int ChameleonNoise::GetNoiseInt(uint32_t subsystem_id, int max_value) {
+  if (max_value <= 0) {
+    return 0;
+  }
+  double noise = GetNoiseValue(subsystem_id);
+  return static_cast<int>(noise * max_value) % max_value;
+}
+
+}  // namespace blink
