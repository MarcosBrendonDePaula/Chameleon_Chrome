+    "Courier New", "Courier", "Verdana", "Georgia",
+    "Tahoma", "Trebuchet MS", "Impact", "Comic Sans MS",
+    "Roboto", "system-ui",
+    "serif", "sans-serif", "monospace", "cursive", "fantasy",
+    "-webkit-standard", "-webkit-serif", "-webkit-sans-serif",
+    "-webkit-monospace",
+  };
+  std::string name = family.Utf8();
+  for (const char* safe : kSafeFonts) {
+    if (name == safe) return true;
+  }
+  return false;
