diff --git a/night_build.cjs b/night_build.cjs
new file mode 100644
index 0000000000..049e33b9fa
--- /dev/null
+++ b/night_build.cjs
@@ -0,0 +1,106 @@
+const { spawn, execSync } = require('child_process');
+
+const BUILD_START_HOUR = 3;  // 3 AM
+const BUILD_STOP_HOUR = 7;   // 7 AM
+const CHECK_INTERVAL = 20000; // checa a cada 20 segundos
+
+let buildProcess = null;
+let building = false;
+
+function log(msg) {
+  console.log(`[${new Date().toLocaleTimeString('pt-BR')}] ${msg}`);
+}
+
+function killBuild() {
+  if (buildProcess) {
+    log('Matando processo de build...');
+    try { buildProcess.kill(); } catch(e) {}
+    buildProcess = null;
+  }
+  ['ninja.exe', 'cl.exe', 'link.exe', 'siso.exe'].forEach(p => {
+    try { execSync(`taskkill /F /IM ${p} 2>nul`, { stdio: 'ignore' }); } catch(e) {}
+  });
+  building = false;
+  log('Build parado.');
+}
+
+function startBuild() {
+  building = true;
+  log('Iniciando build...');
+  log('Rodando gn gen...');
+
+  const gn = spawn('gn', ['gen', 'out/Default'], {
+    cwd: 'E:\\CHAMALEON',
+    stdio: ['ignore', 'pipe', 'pipe'],
+    shell: true,
+    env: { ...process.env, PATH: 'C:\\depot_tools;' + process.env.PATH, DEPOT_TOOLS_WIN_TOOLCHAIN: '0' }
+  });
+
+  gn.stdout.on('data', d => process.stdout.write(d));
+  gn.stderr.on('data', d => process.stderr.write(d));
+
+  gn.on('exit', (code) => {
+    log(`gn gen finalizado (código: ${code})`);
+    if (code !== 0) {
+      log('ERRO: gn gen falhou!');
+      building = false;
+      return;
+    }
+
+    log('Iniciando autoninja -j 16...');
+    buildProcess = spawn('autoninja', ['-C', 'out/Default', 'chrome', '-j', '16'], {
+      cwd: 'E:\\CHAMALEON',
+      stdio: ['ignore', 'pipe', 'pipe'],
+      shell: true,
+      env: { ...process.env, PATH: 'C:\\depot_tools;' + process.env.PATH, DEPOT_TOOLS_WIN_TOOLCHAIN: '0' }
+    });
+
+    buildProcess.stdout.on('data', d => process.stdout.write(d));
+    buildProcess.stderr.on('data', d => process.stderr.write(d));
+
+    buildProcess.on('exit', (code) => {
+      log(`Build finalizado com código: ${code}`);
+      buildProcess = null;
+      building = false;
+    });
+  });
+}
+
+function timeUntil(targetHour) {
+  const now = new Date();
+  const target = new Date(now);
+  target.setHours(targetHour, 0, 0, 0);
+  if (target <= now) target.setDate(target.getDate() + 1);
+  const diff = target - now;
+  const h = Math.floor(diff / 3600000);
+  const m = Math.floor((diff % 3600000) / 60000);
+  const s = Math.floor((diff % 60000) / 1000);
+  return `${h}h${String(m).padStart(2,'0')}m${String(s).padStart(2,'0')}s`;
+}
+
+function check() {
+  const hour = new Date().getHours();
+  const inWindow = hour >= BUILD_START_HOUR && hour < BUILD_STOP_HOUR;
+
+  if (inWindow && !building) {
+    log(`Horário de build detectado (${hour}h) - iniciando!`);
+    startBuild();
+  } else if (!inWindow && building) {
+    log(`Fora do horário de build (${hour}h) - parando!`);
+    killBuild();
+  } else if (inWindow && building) {
+    log(`Compilando... Para em ${timeUntil(BUILD_STOP_HOUR)}`);
+  } else {
+    log(`Aguardando... Inicia em ${timeUntil(BUILD_START_HOUR)}`);
+  }
+}
+
+log('=== Chameleon Night Build - Cron Mode ===');
+log(`Build: ${BUILD_START_HOUR}:00 - ${BUILD_STOP_HOUR}:00`);
+log(`Checando a cada ${CHECK_INTERVAL / 1000}s`);
+log('Deixe rodando. Ctrl+C para cancelar.');
+log('');
+
+// Checa imediatamente e depois a cada 30s
+check();
+setInterval(check, CHECK_INTERVAL);
