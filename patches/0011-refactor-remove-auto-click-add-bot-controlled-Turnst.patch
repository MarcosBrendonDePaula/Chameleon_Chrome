-  LocalFrame* frame = document->GetFrame();
-  if (!frame)
-    return;
-
-  frame->GetTaskRunner(TaskType::kInternalDefault)
-      ->PostDelayedTask(
-          FROM_HERE,
-          BindOnce(&ChameleonAutoClick::TryClickCheckbox,
-                        WrapPersistent(document), retries - 1),
-          base::Milliseconds(500));
-}
-
-}  // namespace blink
