-// static
-void ChameleonAutoClick::TryClickCheckbox(Document* document, int retries) {
-  if (!document || retries <= 0)
-    return;
-
-  // The Turnstile structure is:
-  //   <body>
-  //     #shadow-root (closed)
-  //       <div>
-  //         <input type="checkbox">
-
-  Element* body = document->body();
-  if (!body)
-    goto retry;
-
-  {
-    // Check body's shadow root first (Turnstile attaches to body).
-    ShadowRoot* shadow = body->GetShadowRoot();
-    if (shadow) {
-      DummyExceptionStateForTesting exception_state;
-      Element* checkbox = shadow->querySelector(
-          AtomicString("input[type='checkbox']"), exception_state);
-      if (checkbox) {
-        checkbox->DispatchSimulatedClick(
-            nullptr, SimulatedClickCreationScope::kFromUserAgent);
-        return;  // Done!
-      }
-    }
-
-    // Also search all elements for shadow roots with checkboxes.
-    {
-      DummyExceptionStateForTesting exception_state;
-      StaticElementList* elements = document->querySelectorAll(
-          AtomicString("*"), exception_state);
-      if (elements) {
-        for (unsigned i = 0; i < elements->length(); i++) {
-          Element* el = elements->item(i);
-          ShadowRoot* sr = el->GetShadowRoot();
-          if (!sr)
-            continue;
-          DummyExceptionStateForTesting inner_exception;
-          Element* cb = sr->querySelector(
-              AtomicString("input[type='checkbox']"), inner_exception);
-          if (cb) {
-            cb->DispatchSimulatedClick(
-                nullptr, SimulatedClickCreationScope::kFromUserAgent);
-            return;  // Done!
-          }
-        }
-      }
-    }
-  }
-
-retry:
