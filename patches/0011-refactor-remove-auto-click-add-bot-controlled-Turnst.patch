+"""Bot Turnstile solve via raw WebSocket CDP (cross-process pierce)."""
+import sys
+import os
+import time
+import json
+import urllib.request
+
+sys.path.insert(0, os.path.dirname(__file__))
+from conftest import log, screenshot
+from selenium import webdriver
+import websocket
+
+
+def cdp_send(ws, method, params=None, session_id=None, timeout=10):
+    """Send CDP command and wait for response."""
+    msg_id = int(time.time() * 1000) % 1000000
+    msg = {'id': msg_id, 'method': method, 'params': params or {}}
+    if session_id:
+        msg['sessionId'] = session_id
+    ws.send(json.dumps(msg))
+
+    deadline = time.time() + timeout
+    while time.time() < deadline:
+        try:
+            ws.settimeout(1)
+            resp = ws.recv()
+            data = json.loads(resp)
+            if data.get('id') == msg_id:
+                if 'error' in data:
+                    return None, data['error']
+                return data.get('result', {}), None
+        except websocket.WebSocketTimeoutException:
+            continue
+    return None, {'message': 'timeout'}
+
+
+def test():
+    from conftest import CHROME_BIN, CHROMEDRIVER, PROFILES_DIR, random_seed
+    from selenium.webdriver.chrome.options import Options
+    from selenium.webdriver.chrome.service import Service
+    import random
+
+    seed = random_seed()
+    profile_dir = os.path.join(PROFILES_DIR, f"bot_ws_{''.join(random.choices('abcdef', k=4))}")
+    options = Options()
+    options.binary_location = CHROME_BIN
+    options.add_argument(f"--user-data-dir={profile_dir}")
+    options.add_argument(f"--chameleon-seed={seed}")
+    options.add_argument("--chameleon-locale=en-US,en")
+    options.add_argument("--chameleon-pierce")
+    options.add_argument("--remote-allow-origins=*")
+    service = Service(CHROMEDRIVER)
+    driver = webdriver.Chrome(service=service, options=options)
+    log("=== BOT WEBSOCKET TURNSTILE TEST ===")
+    log(f"Seed: {seed}")
+
+    # Get debugger websocket URL
+    port = driver.capabilities.get('goog:chromeOptions', {}).get('debuggerAddress', '').split(':')[-1]
+    if not port:
+        # Fallback: get from service
+        resp = urllib.request.urlopen(f'http://127.0.0.1:9222/json/version')
+        data = json.loads(resp.read())
+        ws_url = data['webSocketDebuggerUrl']
+    else:
+        resp = urllib.request.urlopen(f'http://127.0.0.1:{port}/json')
+        pages = json.loads(resp.read())
+        ws_url = None
+        for p in pages:
+            if p.get('type') == 'page':
+                ws_url = p.get('webSocketDebuggerUrl')
+                break
+        if not ws_url:
+            log("FAIL: no websocket URL found")
+            driver.quit()
+            return False
+
+    log(f"WS: {ws_url}")
+
+    log("[1] Loading faucet...")
+    driver.get("https://bepolia.faucet.berachain.com/")
+    time.sleep(5)
+
+    log("[2] Filling wallet...")
+    driver.execute_script(
+        "var i=document.querySelectorAll('input')[0];"
+        "i.focus();i.value='0x742d35Cc6634C0532925a3b844Bc9e7595f2bD18';"
+        "i.dispatchEvent(new Event('input',{bubbles:true}))"
+    )
+    time.sleep(8)
+
+    # Connect via websocket
+    ws = websocket.create_connection(ws_url)
+    log("[3] Connected to DevTools WebSocket")
+
+    # Find Turnstile target
+    result, err = cdp_send(ws, 'Target.getTargets')
+    if err:
+        log(f"FAIL: {err}")
+        driver.quit()
+        return False
+
+    turnstile_target = None
+    for t in result.get('targetInfos', []):
+        url = t.get('url', '')
+        if 'challenges.cloudflare.com' in url and 'turnstile' in url:
+            turnstile_target = t
+            break
+
+    if not turnstile_target:
+        log("FAIL: Turnstile target not found")
+        screenshot(driver, "bot_ws_fail")
+        ws.close()
+        driver.quit()
+        return False
+
+    log(f"[4] Found Turnstile: {turnstile_target['targetId']}")
+
+    # Attach to target
+    result, err = cdp_send(ws, 'Target.attachToTarget', {
+        'targetId': turnstile_target['targetId'],
+        'flatten': True
+    })
+    if err:
+        log(f"FAIL attach: {err}")
+        ws.close()
+        driver.quit()
+        return False
+
+    session_id = result['sessionId']
+    log(f"  Attached: {session_id[:20]}...")
+
+    # Get frame tree of the attached target
+    result, err = cdp_send(ws, 'Page.getFrameTree', session_id=session_id)
+    if err:
+        log(f"  Frame tree error: {err}")
+        # Try Runtime.enable first
+        cdp_send(ws, 'Runtime.enable', session_id=session_id)
+        cdp_send(ws, 'Page.enable', session_id=session_id)
+        time.sleep(1)
+        result, err = cdp_send(ws, 'Page.getFrameTree', session_id=session_id)
+
+    if err:
+        log(f"  FAIL frame tree: {err}")
+        ws.close()
+        driver.quit()
+        return False
+
+    frame_id = result['frameTree']['frame']['id']
+    log(f"  Turnstile frame ID: {frame_id}")
+
+    # Create isolated world in the Turnstile frame
+    result, err = cdp_send(ws, 'Page.createIsolatedWorld', {
+        'frameId': frame_id,
+        'worldName': 'chameleon_bot',
+        'grantUniveralAccess': True
+    }, session_id=session_id)
+
+    if err:
+        log(f"  FAIL isolated world: {err}")
+        ws.close()
+        driver.quit()
+        return False
+
+    ctx_id = result['executionContextId']
+    log(f"  Isolated world: context {ctx_id}")
+
+    # Execute pierce in the isolated world - find and click checkbox
+    log("[5] Clicking checkbox...")
+    result, err = cdp_send(ws, 'Runtime.evaluate', {
+        'expression': """
+(function() {
+    var bsr = document.body.shadowRoot;
+    if (bsr) {
+        var cb = bsr.querySelector("input[type='checkbox']");
+        if (cb) { cb.click(); return 'CLICKED body shadow'; }
+    }
+    var all = document.querySelectorAll('*');
+    for (var i = 0; i < all.length; i++) {
+        var sr = all[i].shadowRoot;
+        if (!sr) continue;
+        var cb = sr.querySelector("input[type='checkbox']");
+        if (cb) { cb.click(); return 'CLICKED ' + all[i].tagName; }
+    }
+    return 'no checkbox. body.sr=' + !!bsr + ' els=' + all.length;
+})()
+""",
+        'contextId': ctx_id,
+        'returnByValue': True
+    }, session_id=session_id)
+
+    if err:
+        log(f"  FAIL eval: {err}")
+    else:
+        click_result = result.get('result', {}).get('value', '')
+        log(f"  {click_result}")
+
+    ws.close()
+
+    # Check token
+    clicked = click_result and 'CLICKED' in click_result
+    if clicked:
+        log("[6] Waiting for token (15s)...")
+        token = None
+        for i in range(15):
+            time.sleep(1)
+            try:
+                token = driver.execute_script(
+                    "var t = document.querySelector(\"input[name='cf-turnstile-response']\");"
+                    "return t && t.value ? t.value : '';"
+                )
+                if token and len(token) > 10:
+                    log(f"  [{i+1}s] TOKEN: {token[:60]}...")
+                    break
+            except:
+                pass
+        if not token or len(token) <= 10:
+            log("  No token")
+    else:
+        token = None
+
+    screenshot(driver, "bot_ws")
+    log("\nBrowser open. Ctrl+C to close.")
+    try:
+        while True:
+            time.sleep(60)
+    except KeyboardInterrupt:
+        pass
+    driver.quit()
+    return bool(token and len(token) > 10)
+
+
+if __name__ == "__main__":
+    ok = test()
+    sys.exit(0 if ok else 1)
