+"""Multi-bot: run multiple Chameleon instances in parallel, each solving Turnstile."""
+import sys
+import os
+import time
+import json
+import threading
+import urllib.request
+import random
+
+sys.path.insert(0, os.path.dirname(__file__))
+from conftest import log, screenshot, random_seed, CHROME_BIN, CHROMEDRIVER, PROFILES_DIR
+
+from selenium import webdriver
+from selenium.webdriver.chrome.options import Options
+from selenium.webdriver.chrome.service import Service
+import websocket
+
+
+def cdp_send(ws, method, params=None, session_id=None, timeout=10):
+    msg_id = random.randint(1, 999999)
+    msg = {'id': msg_id, 'method': method, 'params': params or {}}
+    if session_id:
+        msg['sessionId'] = session_id
+    ws.send(json.dumps(msg))
+
+    deadline = time.time() + timeout
+    while time.time() < deadline:
+        try:
+            ws.settimeout(1)
+            resp = ws.recv()
+            data = json.loads(resp)
+            if data.get('id') == msg_id:
+                if 'error' in data:
+                    return None, data['error']
+                return data.get('result', {}), None
+        except websocket.WebSocketTimeoutException:
+            continue
+    return None, {'message': 'timeout'}
+
+
+def solve_turnstile(ws):
+    """Find Turnstile iframe and click checkbox via WebSocket CDP."""
+    # Find Turnstile target
+    result, err = cdp_send(ws, 'Target.getTargets')
+    if err:
+        return False, f"getTargets: {err}"
+
+    turnstile = None
+    for t in result.get('targetInfos', []):
+        url = t.get('url', '')
+        if 'challenges.cloudflare.com' in url and 'turnstile' in url:
+            turnstile = t
+            break
+
+    if not turnstile:
+        return False, "Turnstile target not found"
+
+    # Attach
+    result, err = cdp_send(ws, 'Target.attachToTarget', {
+        'targetId': turnstile['targetId'],
+        'flatten': True
+    })
+    if err:
+        return False, f"attach: {err}"
+
+    sid = result['sessionId']
+
+    # Get frame tree
+    cdp_send(ws, 'Page.enable', session_id=sid)
+    cdp_send(ws, 'Runtime.enable', session_id=sid)
+    time.sleep(1)
+
+    result, err = cdp_send(ws, 'Page.getFrameTree', session_id=sid)
+    if err:
+        return False, f"frameTree: {err}"
+
+    frame_id = result['frameTree']['frame']['id']
+
+    # Create isolated world
+    result, err = cdp_send(ws, 'Page.createIsolatedWorld', {
+        'frameId': frame_id,
+        'worldName': 'chameleon_bot',
+        'grantUniveralAccess': True
+    }, session_id=sid)
+    if err:
+        return False, f"isolatedWorld: {err}"
+
+    ctx_id = result['executionContextId']
+
+    # Click checkbox
+    result, err = cdp_send(ws, 'Runtime.evaluate', {
+        'expression': """
+(function() {
+    var bsr = document.body.shadowRoot;
+    if (bsr) {
+        var cb = bsr.querySelector("input[type='checkbox']");
+        if (cb) { cb.click(); return 'CLICKED'; }
+    }
+    var all = document.querySelectorAll('*');
+    for (var i = 0; i < all.length; i++) {
+        var sr = all[i].shadowRoot;
+        if (!sr) continue;
+        var cb = sr.querySelector("input[type='checkbox']");
+        if (cb) { cb.click(); return 'CLICKED'; }
+    }
+    return 'no checkbox';
+})()
+""",
+        'contextId': ctx_id,
+        'returnByValue': True
+    }, session_id=sid)
+
+    if err:
+        return False, f"eval: {err}"
+
+    val = result.get('result', {}).get('value', '')
+    return 'CLICKED' in val, val
+
+
+def run_bot(bot_id, wallet, results):
+    """Run a single bot instance."""
+    prefix = f"[Bot {bot_id}]"
+    seed = random_seed()
+    profile = os.path.join(PROFILES_DIR, f"multi_{bot_id}_{seed[:8]}")
+
+    log(f"{prefix} Starting... seed={seed[:16]}...")
+
+    options = Options()
+    options.binary_location = CHROME_BIN
+    options.add_argument(f"--user-data-dir={profile}")
+    options.add_argument(f"--chameleon-seed={seed}")
+    options.add_argument("--chameleon-locale=en-US,en")
+    options.add_argument("--chameleon-pierce")
+    options.add_argument("--remote-allow-origins=*")
+
+    service = Service(CHROMEDRIVER)
+    try:
+        driver = webdriver.Chrome(service=service, options=options)
+    except Exception as e:
+        log(f"{prefix} FAIL: driver start: {str(e)[:80]}")
+        results[bot_id] = {'status': 'error', 'error': str(e)[:80]}
+        return
+
+    try:
+        # Get WS URL
+        port = driver.capabilities.get('goog:chromeOptions', {}).get('debuggerAddress', '').split(':')[-1]
+        resp = urllib.request.urlopen(f'http://127.0.0.1:{port}/json')
+        pages = json.loads(resp.read())
+        ws_url = None
+        for p in pages:
+            if p.get('type') == 'page':
+                ws_url = p.get('webSocketDebuggerUrl')
+                break
+
+        if not ws_url:
+            log(f"{prefix} FAIL: no WS URL")
+            results[bot_id] = {'status': 'error', 'error': 'no WS URL'}
+            driver.quit()
+            return
+
+        # Load page
+        log(f"{prefix} Loading faucet...")
+        driver.get("https://bepolia.faucet.berachain.com/")
+        time.sleep(5)
+
+        # Fill wallet
+        driver.execute_script(
+            f"var i=document.querySelectorAll('input')[0];"
+            f"i.focus();i.value='{wallet}';"
+            f"i.dispatchEvent(new Event('input',{{bubbles:true}}))"
+        )
+        time.sleep(8)
+
+        # Connect WS and solve
+        ws = websocket.create_connection(ws_url)
+        log(f"{prefix} Solving Turnstile...")
+
+        clicked, msg = solve_turnstile(ws)
+        log(f"{prefix} Click: {msg}")
+        ws.close()
+
+        # Check token
+        token = None
+        if clicked:
+            for i in range(15):
+                time.sleep(1)
+                try:
+                    token = driver.execute_script(
+                        "var t = document.querySelector(\"input[name='cf-turnstile-response']\");"
+                        "return t && t.value ? t.value : '';"
+                    )
+                    if token and len(token) > 10:
+                        log(f"{prefix} TOKEN: {token[:40]}...")
+                        break
+                except:
+                    pass
+
+        screenshot(driver, f"multi_bot_{bot_id}")
+
+        results[bot_id] = {
+            'status': 'success' if token and len(token) > 10 else 'no_token',
+            'clicked': clicked,
+            'seed': seed[:16],
+            'token': token[:40] if token and len(token) > 10 else None
+        }
+
+    except Exception as e:
+        log(f"{prefix} ERROR: {str(e)[:100]}")
+        results[bot_id] = {'status': 'error', 'error': str(e)[:100]}
+
+    finally:
+        try:
+            driver.quit()
+        except:
+            pass
+
+
+def main():
+    import argparse
+    parser = argparse.ArgumentParser(description='Multi-bot Turnstile solver')
+    parser.add_argument('-n', '--num-bots', type=int, default=2, help='Number of bots')
+    parser.add_argument('-w', '--wallet', default='0x742d35Cc6634C0532925a3b844Bc9e7595f2bD18',
+                        help='Wallet address')
+    args = parser.parse_args()
+
+    log(f"=== MULTI-BOT: {args.num_bots} bots ===\n")
+
+    results = {}
+    threads = []
+
+    for i in range(args.num_bots):
+        t = threading.Thread(target=run_bot, args=(i, args.wallet, results))
+        t.start()
+        threads.append(t)
+        time.sleep(2)  # Stagger starts to avoid port conflicts
+
+    for t in threads:
+        t.join()
+
+    log("\n=== RESULTS ===")
+    success = 0
+    for i in range(args.num_bots):
+        r = results.get(i, {'status': 'unknown'})
+        status = r.get('status', 'unknown')
+        if status == 'success':
+            success += 1
+        log(f"  Bot {i}: {status} {r.get('seed', '')}")
+
+    log(f"\n{success}/{args.num_bots} successful")
+
+
+if __name__ == "__main__":
+    main()
