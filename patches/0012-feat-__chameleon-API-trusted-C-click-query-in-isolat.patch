@@ -0,0 +1,188 @@
+"""Test __chameleon.click() trusted click via WebSocket CDP cross-process."""
+import sys
+import os
+import time
+import json
+import urllib.request
+import random
+
+sys.path.insert(0, os.path.dirname(__file__))
+from conftest import log, screenshot, random_seed, CHROME_BIN, CHROMEDRIVER, PROFILES_DIR
+
+from selenium import webdriver
+from selenium.webdriver.chrome.options import Options
+from selenium.webdriver.chrome.service import Service
+import websocket
+
+
+def cdp_send(ws, method, params=None, session_id=None, timeout=10):
+    msg_id = random.randint(1, 999999)
+    msg = {'id': msg_id, 'method': method, 'params': params or {}}
+    if session_id:
+        msg['sessionId'] = session_id
+    ws.send(json.dumps(msg))
+    deadline = time.time() + timeout
+    while time.time() < deadline:
+        try:
+            ws.settimeout(1)
+            data = json.loads(ws.recv())
+            if data.get('id') == msg_id:
+                return data.get('result', {}), data.get('error')
+        except websocket.WebSocketTimeoutException:
+            continue
+    return None, {'message': 'timeout'}
+
+
+def test():
+    seed = random_seed()
+    profile = os.path.join(PROFILES_DIR, f"trusted_{''.join(random.choices('abcdef', k=4))}")
+
+    options = Options()
+    options.binary_location = CHROME_BIN
+    options.add_argument(f"--user-data-dir={profile}")
+    options.add_argument(f"--chameleon-seed={seed}")
+    options.add_argument("--chameleon-locale=en-US,en")
+    options.add_argument("--chameleon-pierce")
+    options.add_argument("--remote-allow-origins=*")
+
+    service = Service(CHROMEDRIVER)
+    driver = webdriver.Chrome(service=service, options=options)
+
+    log("=== TRUSTED CLICK TEST ===")
+    log(f"Seed: {seed[:16]}...")
+
+    # Get WS URL
+    port = driver.capabilities.get('goog:chromeOptions', {}).get('debuggerAddress', '').split(':')[-1]
+    resp = urllib.request.urlopen(f'http://127.0.0.1:{port}/json')
+    pages = json.loads(resp.read())
+    ws_url = next(p['webSocketDebuggerUrl'] for p in pages if p.get('type') == 'page')
+
+    log("[1] Loading faucet...")
+    driver.get("https://bepolia.faucet.berachain.com/")
+    time.sleep(5)
+
+    log("[2] Filling wallet...")
+    driver.execute_script(
+        "var i=document.querySelectorAll('input')[0];"
+        "i.focus();i.value='0x742d35Cc6634C0532925a3b844Bc9e7595f2bD18';"
+        "i.dispatchEvent(new Event('input',{bubbles:true}))"
+    )
+    time.sleep(8)
+
+    # Connect WS
+    ws = websocket.create_connection(ws_url)
+
+    # Find Turnstile target
+    result, err = cdp_send(ws, 'Target.getTargets')
+    turnstile = None
+    for t in result.get('targetInfos', []):
+        url = t.get('url', '')
+        if 'challenges.cloudflare.com' in url and 'turnstile' in url:
+            turnstile = t
+            break
+
+    if not turnstile:
+        log("FAIL: Turnstile not found")
+        ws.close()
+        driver.quit()
+        return False
+
+    log(f"[3] Found Turnstile: {turnstile['targetId'][:20]}...")
+
+    # Attach
+    result, err = cdp_send(ws, 'Target.attachToTarget', {
+        'targetId': turnstile['targetId'], 'flatten': True
+    })
+    sid = result['sessionId']
+    log(f"  Attached: {sid[:20]}...")
+
+    # Enable + get frame
+    cdp_send(ws, 'Page.enable', session_id=sid)
+    cdp_send(ws, 'Runtime.enable', session_id=sid)
+    time.sleep(1)
+
+    result, err = cdp_send(ws, 'Page.getFrameTree', session_id=sid)
+    if err:
+        log(f"FAIL frame tree: {err}")
+        ws.close()
+        driver.quit()
+        return False
+
+    frame_id = result['frameTree']['frame']['id']
+
+    # Create isolated world
+    result, err = cdp_send(ws, 'Page.createIsolatedWorld', {
+        'frameId': frame_id, 'worldName': 'chameleon_bot'
+    }, session_id=sid)
+    if err:
+        log(f"FAIL isolated world: {err}")
+        ws.close()
+        driver.quit()
+        return False
+
+    ctx_id = result['executionContextId']
+    log(f"[4] Isolated world: ctx={ctx_id}")
+
+    # First check if __chameleon is available
+    result, err = cdp_send(ws, 'Runtime.evaluate', {
+        'expression': 'typeof __chameleon',
+        'contextId': ctx_id,
+        'returnByValue': True
+    }, session_id=sid)
+    chameleon_type = result.get('result', {}).get('value', 'undefined') if result else 'error'
+    log(f"  __chameleon type: {chameleon_type}")
+
+    # Use __chameleon.query to find checkbox, then __chameleon.click
+    log("[5] Trusted click via __chameleon...")
+    result, err = cdp_send(ws, 'Runtime.evaluate', {
+        'expression': """
+(function() {
+    if (typeof __chameleon === 'undefined') return 'no __chameleon';
+    var el = __chameleon.query("input[type='checkbox']");
+    if (!el) return 'no checkbox found';
+    __chameleon.click(el);
+    return 'TRUSTED CLICK done';
+})()
+""",
+        'contextId': ctx_id,
+        'returnByValue': True
+    }, session_id=sid)
+
+    click_result = result.get('result', {}).get('value', '') if result else ''
+    log(f"  Result: {click_result}")
+
+    ws.close()
+
+    # Check token
+    token = None
+    if 'TRUSTED CLICK' in str(click_result):
+        log("[6] Waiting for token (15s)...")
+        for i in range(15):
+            time.sleep(1)
+            try:
+                token = driver.execute_script(
+                    "var t = document.querySelector(\"input[name='cf-turnstile-response']\");"
+                    "return t && t.value ? t.value : '';"
+                )
+                if token and len(token) > 10:
+                    log(f"  [{i+1}s] TOKEN: {token[:60]}...")
+                    break
+            except:
+                pass
+        if not token or len(token) <= 10:
+            log("  No token")
+
+    screenshot(driver, "trusted_click")
+    log("\nBrowser open. Ctrl+C to close.")
+    try:
+        while True:
+            time.sleep(60)
+    except KeyboardInterrupt:
+        pass
+    driver.quit()
+    return bool(token and len(token) > 10)
+
+
+if __name__ == "__main__":
+    ok = test()
+    sys.exit(0 if ok else 1)
