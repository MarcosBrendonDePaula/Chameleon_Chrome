index 0000000000..2536848ea5
--- /dev/null
+++ b/third_party/blink/renderer/core/chameleon/chameleon_binding.cc
@@ -0,0 +1,190 @@
+// Copyright 2025 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "third_party/blink/renderer/core/chameleon/chameleon_binding.h"
+
+#include "base/command_line.h"
+#include "third_party/blink/renderer/bindings/core/v8/to_v8_traits.h"
+#include "third_party/blink/renderer/bindings/core/v8/v8_element.h"
+#include "third_party/blink/renderer/core/dom/element.h"
+#include "third_party/blink/renderer/core/dom/events/simulated_click_options.h"
+#include "third_party/blink/renderer/core/dom/shadow_root.h"
+#include "third_party/blink/renderer/core/dom/static_node_list.h"
+#include "third_party/blink/renderer/core/frame/local_dom_window.h"
+#include "third_party/blink/renderer/platform/bindings/dom_wrapper_world.h"
+#include "third_party/blink/renderer/platform/bindings/exception_state.h"
+#include "third_party/blink/renderer/platform/bindings/script_state.h"
+#include "third_party/blink/renderer/platform/bindings/v8_binding.h"
+#include "third_party/blink/renderer/platform/wtf/text/atomic_string.h"
+#include "v8/include/v8-context.h"
+#include "v8/include/v8-function.h"
+#include "v8/include/v8-isolate.h"
+#include "v8/include/v8-object.h"
+#include "v8/include/v8-template.h"
+#include "v8/include/v8-value.h"
+
+namespace blink {
+
+// static
+bool ChameleonBinding::IsPierceEnabled() {
+  static bool checked = false;
+  static bool enabled = false;
+  if (!checked) {
+    checked = true;
+    if (base::CommandLine::InitializedForCurrentProcess()) {
+      enabled = base::CommandLine::ForCurrentProcess()->HasSwitch(
+          "chameleon-pierce");
+    }
+  }
+  return enabled;
+}
+
+// static
+void ChameleonBinding::Install(v8::Local<v8::Context> context) {
+  if (!IsPierceEnabled())
+    return;
+
+  // Only install in isolated worlds, never in main world.
+  v8::Isolate* isolate = v8::Isolate::GetCurrent();
+  ScriptState* script_state = ScriptState::From(isolate, context);
+  if (!script_state)
+    return;
+  const DOMWrapperWorld& world = script_state->World();
+  if (world.IsMainWorld())
+    return;
+
+  v8::HandleScope handle_scope(isolate);
+  v8::Context::Scope context_scope(context);
+
+  // Create __chameleon object
+  v8::Local<v8::Object> chameleon_obj = v8::Object::New(isolate);
+
+  // Add click(element) function
+  v8::Local<v8::Function> click_fn;
+  if (v8::Function::New(context, ClickCallback).ToLocal(&click_fn)) {
+    chameleon_obj
+        ->Set(context,
+              v8::String::NewFromUtf8Literal(isolate, "click"),
+              click_fn)
+        .Check();
+  }
+
+  // Add query(selector) function
+  v8::Local<v8::Function> query_fn;
+  if (v8::Function::New(context, QueryCallback).ToLocal(&query_fn)) {
+    chameleon_obj
+        ->Set(context,
+              v8::String::NewFromUtf8Literal(isolate, "query"),
+              query_fn)
+        .Check();
+  }
+
+  // Set __chameleon on global
+  context->Global()
+      ->Set(context,
+            v8::String::NewFromUtf8Literal(isolate, "__chameleon"),
+            chameleon_obj)
+      .Check();
+}
+
+// static
+void ChameleonBinding::ClickCallback(
+    const v8::FunctionCallbackInfo<v8::Value>& args) {
+  v8::Isolate* isolate = args.GetIsolate();
+
+  if (args.Length() < 1 || !args[0]->IsObject()) {
+    isolate->ThrowException(v8::Exception::TypeError(
+        v8::String::NewFromUtf8Literal(isolate,
+                                        "__chameleon.click: argument must be an Element")));
+    return;
+  }
+
+  // Convert V8 object to Blink Element
+  ScriptState* script_state =
+      ScriptState::ForCurrentRealm(args);
+  if (!script_state)
+    return;
+
+  Element* element = V8Element::ToWrappable(isolate, args[0]);
+  if (!element) {
+    isolate->ThrowException(v8::Exception::TypeError(
+        v8::String::NewFromUtf8Literal(isolate,
+                                        "__chameleon.click: argument is not an Element")));
+    return;
+  }
+
+  // Dispatch trusted click
+  element->DispatchSimulatedClick(
+      nullptr, SimulatedClickCreationScope::kFromUserAgent);
+
+  args.GetReturnValue().Set(v8::Boolean::New(isolate, true));
+}
+
+// static
+void ChameleonBinding::QueryCallback(
+    const v8::FunctionCallbackInfo<v8::Value>& args) {
+  v8::Isolate* isolate = args.GetIsolate();
+
+  if (args.Length() < 1 || !args[0]->IsString()) {
+    isolate->ThrowException(v8::Exception::TypeError(
+        v8::String::NewFromUtf8Literal(isolate,
+                                        "__chameleon.query: argument must be a CSS selector string")));
+    return;
+  }
+
+  v8::String::Utf8Value selector_utf8(isolate, args[0]);
+  if (!*selector_utf8)
+    return;
+
+  AtomicString selector(*selector_utf8);
+
+  ScriptState* script_state =
+      ScriptState::ForCurrentRealm(args);
+  if (!script_state)
+    return;
+
+  // Get the document from the current context
+  LocalDOMWindow* window = LocalDOMWindow::From(script_state);
+  if (!window || !window->document())
+    return;
+
+  Document* document = window->document();
+
+  // Deep query: search through closed shadow roots
+  Element* found = DeepQuery(*document, selector);
+
+  if (found) {
+    args.GetReturnValue().Set(
+        ToV8Traits<Element>::ToV8(script_state, found));
+  } else {
+    args.GetReturnValue().SetNull();
+  }
+}
+
+// static - not in header, internal helper
+Element* ChameleonBinding::DeepQuery(ContainerNode& root,
+                                      const AtomicString& selector) {
+  DummyExceptionStateForTesting exception_state;
+  Element* found = root.querySelector(selector, exception_state);
+  if (found)
+    return found;
+
+  StaticElementList* elements =
+      root.querySelectorAll(AtomicString("*"), exception_state);
+  if (!elements)
+    return nullptr;
+
+  for (unsigned i = 0; i < elements->length(); i++) {
+    Element* el = elements->item(i);
+    ShadowRoot* sr = el->GetShadowRoot();
+    if (!sr)
+      continue;
+    Element* in_shadow = DeepQuery(*sr, selector);
+    if (in_shadow)
+      return in_shadow;
+  }
+  return nullptr;
+}
+
+}  // namespace blink
