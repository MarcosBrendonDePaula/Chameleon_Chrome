+// Copyright 2025 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef THIRD_PARTY_BLINK_RENDERER_CORE_CHAMELEON_CHAMELEON_BINDING_H_
+#define THIRD_PARTY_BLINK_RENDERER_CORE_CHAMELEON_CHAMELEON_BINDING_H_
+
+#include "third_party/blink/renderer/core/core_export.h"
+#include "third_party/blink/renderer/platform/wtf/text/atomic_string.h"
+#include "v8/include/v8-forward.h"
+
+namespace blink {
+
+class ContainerNode;
+class Element;
+
+// Installs __chameleon API on isolated world global objects.
+// Only active when --chameleon-pierce is set.
+// Provides:
+//   __chameleon.click(element)  - trusted click (kFromUserAgent, isTrusted=true)
+//   __chameleon.query(selector) - deep query through closed shadow roots
+class CORE_EXPORT ChameleonBinding {
+ public:
+  // Called when a script context is created. Installs __chameleon on
+  // isolated world globals if --chameleon-pierce is set.
+  static void Install(v8::Local<v8::Context> context);
+
+ private:
+  static bool IsPierceEnabled();
+  static void ClickCallback(const v8::FunctionCallbackInfo<v8::Value>& args);
+  static void QueryCallback(const v8::FunctionCallbackInfo<v8::Value>& args);
+  static Element* DeepQuery(ContainerNode& root, const AtomicString& selector);
+};
+
+}  // namespace blink
+
+#endif  // THIRD_PARTY_BLINK_RENDERER_CORE_CHAMELEON_CHAMELEON_BINDING_H_
