+++ b/tests/e2e/test_chameleon_api.py
@@ -0,0 +1,230 @@
+"""E2E: Test all __chameleon API functions."""
+import sys
+import os
+import time
+
+sys.path.insert(0, os.path.dirname(__file__))
+from conftest import make_driver, log, screenshot, pierce_exec
+
+FIXTURE = os.path.join(os.path.dirname(__file__), "fixtures", "chameleon_api_test.html")
+
+
+def run(driver, js):
+    """Run JS in isolated world via pierce_exec, wrapped in IIFE."""
+    wrapped = f"(function() {{ {js} }})()"
+    return pierce_exec(driver, wrapped)
+
+
+def test_api():
+    driver, seed = make_driver(pierce=True, profile_prefix="api_test")
+    log("=== __CHAMELEON API TEST ===\n")
+
+    driver.get(f"file:///{FIXTURE.replace(os.sep, '/')}")
+    time.sleep(2)
+
+    passed = 0
+    total = 0
+
+    # --- 1. click ---
+    total += 1
+    r = run(driver, """
+        var btn = __chameleon.query('#shadow-btn');
+        if (!btn) return 'FAIL: shadow btn not found';
+        __chameleon.click(btn);
+        var status = __chameleon.query('#shadow-status');
+        return __chameleon.text(status);
+    """)
+    ok = r == 'CLICKED'
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] click: {r}")
+
+    # --- 2. focus ---
+    total += 1
+    r = run(driver, """
+        var el = document.getElementById('focus-input');
+        __chameleon.focus(el);
+        return document.getElementById('focus-result').textContent;
+    """)
+    ok = r == 'FOCUSED'
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] focus: {r}")
+
+    # --- 3. hover ---
+    total += 1
+    r = run(driver, """
+        var el = document.getElementById('hover-target');
+        __chameleon.hover(el);
+        return document.getElementById('hover-result').textContent;
+    """)
+    ok = r == 'HOVERED'
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] hover: {r}")
+
+    # --- 4. type ---
+    total += 1
+    r = run(driver, """
+        var el = document.getElementById('type-input');
+        __chameleon.type(el, 'hello world');
+        return document.getElementById('type-result').textContent;
+    """)
+    ok = r == 'typed: hello world'
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] type: {r}")
+
+    # --- 5. check ---
+    total += 1
+    r = run(driver, """
+        var el = document.getElementById('check-box');
+        __chameleon.check(el, true);
+        return document.getElementById('check-result').textContent;
+    """)
+    ok = 'CHECKED' in str(r)
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] check: {r}")
+
+    # --- 6. select ---
+    total += 1
+    r = run(driver, """
+        var el = document.getElementById('select-box');
+        __chameleon.select(el, 'banana');
+        return document.getElementById('select-result').textContent;
+    """)
+    ok = r == 'selected: banana'
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] select: {r}")
+
+    # --- 7. submit ---
+    total += 1
+    r = run(driver, """
+        var form = document.getElementById('test-form');
+        __chameleon.submit(form);
+        return document.getElementById('submit-result').textContent;
+    """)
+    ok = r == 'SUBMITTED'
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] submit: {r}")
+
+    # --- 8. query (deep shadow) ---
+    total += 1
+    r = run(driver, """
+        var el = __chameleon.query('#shadow-text');
+        return el ? __chameleon.text(el) : 'null';
+    """)
+    ok = r == 'Secret shadow content'
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] query (shadow): {r}")
+
+    # --- 9. queryAll ---
+    total += 1
+    r = run(driver, """
+        var els = __chameleon.queryAll('input[type="text"]');
+        return 'found: ' + els.length;
+    """)
+    # Should find: focus-input, type-input, value-input, shadow-input, deep-input = 5
+    ok = r and 'found: 5' in r
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] queryAll: {r}")
+
+    # --- 10. attr ---
+    total += 1
+    r = run(driver, """
+        var el = document.getElementById('attr-target');
+        return __chameleon.attr(el, 'data-custom');
+    """)
+    ok = r == 'hello-world'
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] attr: {r}")
+
+    # --- 11. setAttr ---
+    total += 1
+    r = run(driver, """
+        var el = document.getElementById('attr-target');
+        __chameleon.setAttr(el, 'data-custom', 'changed');
+        return __chameleon.attr(el, 'data-custom');
+    """)
+    ok = r == 'changed'
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] setAttr: {r}")
+
+    # --- 12. text ---
+    total += 1
+    r = run(driver, """
+        var el = document.getElementById('content-target');
+        return __chameleon.text(el);
+    """)
+    ok = r == 'Hello World'
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] text: {r}")
+
+    # --- 13. html ---
+    total += 1
+    r = run(driver, """
+        var el = document.getElementById('content-target');
+        return __chameleon.html(el);
+    """)
+    ok = r and '<strong>' in r
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] html: {r}")
+
+    # --- 14. value ---
+    total += 1
+    r = run(driver, """
+        var el = document.getElementById('value-input');
+        return __chameleon.value(el);
+    """)
+    ok = r == 'initial-value'
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] value: {r}")
+
+    # --- 15. value (shadow) ---
+    total += 1
+    r = run(driver, """
+        var el = __chameleon.query('#shadow-input');
+        return el ? __chameleon.value(el) : 'null';
+    """)
+    ok = r == 'shadow-value'
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] value (shadow): {r}")
+
+    # --- 16. deep nested click ---
+    total += 1
+    r = run(driver, """
+        var btn = __chameleon.query('#deep-btn');
+        if (!btn) return 'FAIL: deep btn not found';
+        __chameleon.click(btn);
+        var status = __chameleon.query('#deep-status');
+        return __chameleon.text(status);
+    """)
+    ok = r == 'DEEP CLICKED'
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] deep nested click: {r}")
+
+    # --- 17. type in shadow input ---
+    total += 1
+    r = run(driver, """
+        var el = __chameleon.query('#shadow-input');
+        if (!el) return 'null';
+        __chameleon.type(el, 'new shadow value');
+        return __chameleon.value(el);
+    """)
+    ok = r == 'new shadow value'
+    if ok: passed += 1
+    log(f"  [{'OK' if ok else 'FAIL'}] type (shadow): {r}")
+
+    # --- 18. main world cannot see __chameleon ---
+    total += 1
+    r = driver.execute_script("return typeof __chameleon")
+    ok = r == 'undefined'
+    if ok: passed += 1
