From b99b2f899bccd78510cb018a35ddc19c47c6d8c4 Mon Sep 17 00:00:00 2001
From: Marcos <marcosbrendonaz@gmail.com>
Date: Fri, 27 Mar 2026 02:58:29 -0300
Subject: [PATCH 15/15] fix: focus/check callbacks + add full API test suite
 (18/18 pass)

- focus: dispatch focus + focusin events for proper listener firing
- check: only click when state needs to change (avoid double toggle)
- conftest: better error reporting in pierce_exec
- Add test_chameleon_api.py testing all 14 __chameleon functions
  including deep shadow DOM, queryAll, type in shadow, etc.

Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>
---
 tests/e2e/conftest.py                         |   6 +-
 tests/e2e/fixtures/chameleon_api_test.html    | 105 ++++++++
 tests/e2e/screenshots/chameleon_api.png       | Bin 0 -> 29855 bytes
 tests/e2e/test_chameleon_api.py               | 230 ++++++++++++++++++
 .../core/chameleon/chameleon_binding.cc       |  22 +-
 5 files changed, 351 insertions(+), 12 deletions(-)
 create mode 100644 tests/e2e/fixtures/chameleon_api_test.html
 create mode 100644 tests/e2e/screenshots/chameleon_api.png
 create mode 100644 tests/e2e/test_chameleon_api.py

diff --git a/tests/e2e/conftest.py b/tests/e2e/conftest.py
index fc2266215d..92388916e4 100644
--- a/tests/e2e/conftest.py
+++ b/tests/e2e/conftest.py
@@ -81,5 +81,9 @@ def pierce_exec(driver, script, frame_id=None):
         'awaitPromise': False,
     })
     if 'exceptionDetails' in result:
-        raise RuntimeError(result['exceptionDetails']['text'])
+        detail = result['exceptionDetails']
+        text = detail.get('text', 'Unknown error')
+        exc = detail.get('exception', {})
+        desc = exc.get('description', '')
+        raise RuntimeError(f"{text}: {desc}" if desc else text)
     return result['result'].get('value')
diff --git a/tests/e2e/fixtures/chameleon_api_test.html b/tests/e2e/fixtures/chameleon_api_test.html
new file mode 100644
index 0000000000..ffaf60f490
--- /dev/null
+++ b/tests/e2e/fixtures/chameleon_api_test.html
@@ -0,0 +1,105 @@
+<!DOCTYPE html>
+<html>
+<head><title>Chameleon API Test</title></head>
+<body>
+<h1>__chameleon API Test Page</h1>
+
+<!-- focus test -->
+<input type="text" id="focus-input" placeholder="focus test">
+<p id="focus-result">not focused</p>
+
+<!-- type test -->
+<input type="text" id="type-input" placeholder="type test">
+<p id="type-result">empty</p>
+
+<!-- hover test -->
+<div id="hover-target" style="padding:10px; background:#eee; display:inline-block">Hover me</div>
+<p id="hover-result">no hover</p>
+
+<!-- check test -->
+<input type="checkbox" id="check-box"> Check me
+<p id="check-result">unchecked</p>
+
+<!-- select test -->
+<select id="select-box">
+  <option value="">Choose...</option>
+  <option value="apple">Apple</option>
+  <option value="banana">Banana</option>
+  <option value="cherry">Cherry</option>
+</select>
+<p id="select-result">none selected</p>
+
+<!-- submit test -->
+<form id="test-form" onsubmit="document.getElementById('submit-result').textContent='SUBMITTED'; return false;">
+  <input type="hidden" name="data" value="test">
+  <button type="submit">Submit</button>
+</form>
+<p id="submit-result">not submitted</p>
+
+<!-- attr test -->
+<div id="attr-target" data-custom="hello-world" data-count="42">Has attributes</div>
+
+<!-- text/html test -->
+<div id="content-target">Hello <strong>World</strong></div>
+
+<!-- value test -->
+<input type="text" id="value-input" value="initial-value">
+
+<!-- closed shadow DOM test -->
+<div id="shadow-host"></div>
+<p id="shadow-result">waiting</p>
+
+<!-- nested shadow test -->
+<div id="deep-host"></div>
+<p id="deep-result">waiting</p>
+
+<script>
+// Event listeners
+document.getElementById('focus-input').addEventListener('focus', function() {
+  document.getElementById('focus-result').textContent = 'FOCUSED';
+});
+
+document.getElementById('type-input').addEventListener('input', function(e) {
+  document.getElementById('type-result').textContent = 'typed: ' + e.target.value;
+});
+
+document.getElementById('hover-target').addEventListener('mouseenter', function() {
+  document.getElementById('hover-result').textContent = 'HOVERED';
+});
+
+document.getElementById('check-box').addEventListener('change', function(e) {
+  document.getElementById('check-result').textContent = e.target.checked ? 'CHECKED' : 'unchecked';
+});
+
+document.getElementById('select-box').addEventListener('change', function(e) {
+  document.getElementById('select-result').textContent = 'selected: ' + e.target.value;
+});
+
+// Closed shadow DOM with form inside
+var host = document.getElementById('shadow-host');
+var shadow = host.attachShadow({mode: 'closed'});
+shadow.innerHTML = '<div style="padding:10px; background:#f0f0f0; border:1px solid #ccc">' +
+  '<p id="shadow-text">Secret shadow content</p>' +
+  '<input type="text" id="shadow-input" value="shadow-value">' +
+  '<button id="shadow-btn">Shadow Button</button>' +
+  '<p id="shadow-status">idle</p></div>';
+shadow.querySelector('#shadow-btn').addEventListener('click', function() {
+  shadow.querySelector('#shadow-status').textContent = 'CLICKED';
+});
+
+// Deep nested: closed > closed > input
+var deepHost = document.getElementById('deep-host');
+var shadow1 = deepHost.attachShadow({mode: 'closed'});
+var inner = document.createElement('div');
+inner.id = 'inner-host';
+shadow1.appendChild(inner);
+var shadow2 = inner.attachShadow({mode: 'closed'});
+shadow2.innerHTML = '<input type="text" id="deep-input" value="deep-value">' +
+  '<button id="deep-btn">Deep Button</button>' +
+  '<p id="deep-status">idle</p>';
+shadow2.querySelector('#deep-btn').addEventListener('click', function() {
+  shadow2.querySelector('#deep-status').textContent = 'DEEP CLICKED';
+});
+</script>
+</body>
+</html>
