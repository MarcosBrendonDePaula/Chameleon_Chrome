+// static
+Element* ChameleonBinding::DeepQuery(ContainerNode& root,
+                                      const AtomicString& selector) {
+  DummyExceptionStateForTesting exception_state;
+  Element* found = root.querySelector(selector, exception_state);
+  if (found)
+    return found;
+
+  StaticElementList* elements =
+      root.querySelectorAll(AtomicString("*"), exception_state);
+  if (!elements)
+    return nullptr;
+
+  for (unsigned i = 0; i < elements->length(); i++) {
+    Element* el = elements->item(i);
+    ShadowRoot* sr = el->GetShadowRoot();
+    if (!sr)
+      continue;
+    Element* in_shadow = DeepQuery(*sr, selector);
+    if (in_shadow)
+      return in_shadow;
+  }
+  return nullptr;
+}
+
+// static
+void ChameleonBinding::DeepQueryAll(ContainerNode& root,
+                                     const AtomicString& selector,
+                                     HeapVector<Member<Element>>& results) {
+  DummyExceptionStateForTesting exception_state;
+  StaticElementList* found = root.querySelectorAll(selector, exception_state);
+  if (found) {
+    for (unsigned i = 0; i < found->length(); i++)
+      results.push_back(found->item(i));
+  }
+
+  StaticElementList* all =
+      root.querySelectorAll(AtomicString("*"), exception_state);
+  if (!all)
+    return;
+
+  for (unsigned i = 0; i < all->length(); i++) {
+    Element* el = all->item(i);
+    ShadowRoot* sr = el->GetShadowRoot();
+    if (!sr)
+      continue;
+    DeepQueryAll(*sr, selector, results);
+  }
+}
