+// static
+void ChameleonBinding::AddFunction(v8::Isolate* isolate,
+                                    v8::Local<v8::Context> context,
+                                    v8::Local<v8::Object> obj,
+                                    const char* name,
+                                    v8::FunctionCallback callback) {
+  v8::Local<v8::Function> fn;
+  if (v8::Function::New(context, callback).ToLocal(&fn)) {
+    obj->Set(context,
+             v8::String::NewFromUtf8(isolate, name).ToLocalChecked(),
+             fn)
+        .Check();
+  }
+}
+
+// static
+Element* ChameleonBinding::UnwrapElement(
+    v8::Isolate* isolate,
+    const v8::FunctionCallbackInfo<v8::Value>& args,
+    int index,
+    const char* fn_name) {
+  if (args.Length() <= index || !args[index]->IsObject()) {
+    std::string msg = std::string(fn_name) + ": argument must be an Element";
+    isolate->ThrowException(v8::Exception::TypeError(
+        v8::String::NewFromUtf8(isolate, msg.c_str()).ToLocalChecked()));
+    return nullptr;
+  }
+  Element* el = V8Element::ToWrappable(isolate, args[index]);
+  if (!el) {
+    std::string msg = std::string(fn_name) + ": argument is not an Element";
+    isolate->ThrowException(v8::Exception::TypeError(
+        v8::String::NewFromUtf8(isolate, msg.c_str()).ToLocalChecked()));
+  }
+  return el;
+}
