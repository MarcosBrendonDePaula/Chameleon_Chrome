+void ChameleonBinding::SelectCallback(
+    const v8::FunctionCallbackInfo<v8::Value>& args) {
+  v8::Isolate* isolate = args.GetIsolate();
+  Element* el = UnwrapElement(isolate, args, 0, "__chameleon.select");
+  if (!el)
+    return;
+
+  if (args.Length() < 2 || !args[1]->IsString()) {
+    isolate->ThrowException(v8::Exception::TypeError(
+        v8::String::NewFromUtf8Literal(isolate,
+            "__chameleon.select: second argument must be a string")));
+    return;
+  }
+
+  auto* select = DynamicTo<HTMLSelectElement>(el);
+  if (!select) {
+    isolate->ThrowException(v8::Exception::TypeError(
+        v8::String::NewFromUtf8Literal(isolate,
+            "__chameleon.select: element must be a <select>")));
+    return;
+  }
+
+  v8::String::Utf8Value val(isolate, args[1]);
+  select->setValueForBinding(AtomicString(*val));
+  select->DispatchEvent(*Event::Create(event_type_names::kInput));
+  select->DispatchEvent(*Event::Create(event_type_names::kChange));
   args.GetReturnValue().Set(v8::Boolean::New(isolate, true));
