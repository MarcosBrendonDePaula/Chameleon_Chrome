+// __chameleon.attr(element, name) - get attribute
+// static
+void ChameleonBinding::AttrCallback(
+    const v8::FunctionCallbackInfo<v8::Value>& args) {
+  v8::Isolate* isolate = args.GetIsolate();
+  Element* el = UnwrapElement(isolate, args, 0, "__chameleon.attr");
+  if (!el)
+    return;
+
+  if (args.Length() < 2 || !args[1]->IsString()) {
+    isolate->ThrowException(v8::Exception::TypeError(
+        v8::String::NewFromUtf8Literal(isolate,
+            "__chameleon.attr: second argument must be attribute name")));
+    return;
+  }
+
+  v8::String::Utf8Value name(isolate, args[1]);
+  String value = el->getAttribute(AtomicString(*name));
+  if (value.IsNull()) {
+    args.GetReturnValue().SetNull();
+  } else {
+    args.GetReturnValue().Set(
+        v8::String::NewFromUtf8(isolate, value.Utf8().c_str())
+            .ToLocalChecked());
+  }
+}
