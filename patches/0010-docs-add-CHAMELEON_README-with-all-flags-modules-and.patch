+"""Test auto-click Turnstile with a completely fresh profile."""
+import sys
+import os
+import time
+import random
+
+sys.path.insert(0, os.path.dirname(__file__))
+from conftest import make_driver, log, screenshot
+
+
+def test():
+    driver, seed = make_driver(pierce=True, profile_prefix="fresh")
+    log(f"=== FRESH PROFILE TURNSTILE TEST ===")
+    log(f"Seed: {seed}")
+
+    log("[1] Loading faucet...")
+    driver.get("https://bepolia.faucet.berachain.com/")
+    time.sleep(5)
+
+    log("[2] Filling wallet...")
+    driver.execute_script(
+        "var i=document.querySelectorAll('input')[0];"
+        "i.focus();i.value='0x742d35Cc6634C0532925a3b844Bc9e7595f2bD18';"
+        "i.dispatchEvent(new Event('input',{bubbles:true}))"
+    )
+
+    log("[3] Waiting for auto-click + token (30s)...")
+    token = None
+    for i in range(30):
+        time.sleep(1)
+        try:
+            token = driver.execute_script(
+                "var t = document.querySelector(\"input[name='cf-turnstile-response']\");"
+                "return t && t.value ? t.value : '';"
+            )
+            if token and len(token) > 10:
+                log(f"  [{i+1}s] TOKEN: {token[:60]}...")
+                break
+        except:
+            pass
+        if (i + 1) % 10 == 0:
+            log(f"  [{i+1}s] waiting...")
+
+    if not token or len(token) <= 10:
+        log("  No token after 30s")
+
+    screenshot(driver, "fresh_profile")
+    log("\nBrowser open. Ctrl+C to close.")
+    try:
+        while True:
+            time.sleep(60)
+    except KeyboardInterrupt:
+        pass
+    driver.quit()
+    return bool(token and len(token) > 10)
+
+
+if __name__ == "__main__":
+    ok = test()
+    sys.exit(0 if ok else 1)
