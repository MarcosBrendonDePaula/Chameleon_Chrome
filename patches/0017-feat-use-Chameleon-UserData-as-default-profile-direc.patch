From d016f6bc79449f8b4dbf0a99fcea9bb3aae21b63 Mon Sep 17 00:00:00 2001
From: Marcos <marcosbrendonaz@gmail.com>
Date: Fri, 27 Mar 2026 12:49:41 -0300
Subject: [PATCH 17/17] feat: use Chameleon\UserData as default profile
 directory

Change default user data directory from Chromium\User Data to
Chameleon\UserData to avoid conflicts with Chrome/Chromium installations.
Path: %LOCALAPPDATA%\Chameleon\UserData

Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>
---
 chrome/install_static/user_data_dir.cc | 5 ++---
 1 file changed, 2 insertions(+), 3 deletions(-)

diff --git a/chrome/install_static/user_data_dir.cc b/chrome/install_static/user_data_dir.cc
index 6b231841bf68c..e2789677390f0 100644
--- a/chrome/install_static/user_data_dir.cc
+++ b/chrome/install_static/user_data_dir.cc
@@ -97,9 +97,8 @@ bool GetDefaultUserDataDirectory(const InstallConstants& mode,
   result->swap(user_data_dir);
   if ((*result)[result->length() - 1] != L'\\')
     result->push_back(L'\\');
-  AppendChromeInstallSubDirectory(mode, true /* include_suffix */, result);
-  result->push_back(L'\\');
-  result->append(L"User Data");
+  // Chameleon: use own directory to avoid conflicts with Chrome/Chromium.
+  result->append(L"Chameleon\\UserData");
   return true;
 }
 
