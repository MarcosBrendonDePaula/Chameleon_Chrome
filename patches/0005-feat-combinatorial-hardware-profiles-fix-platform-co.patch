+HardwareProfile BuildProfile() {
+  HardwareProfile p;
+  p.platform = "Win32";
+  p.ua_os_part = "Windows NT 10.0; Win64; x64";
+
+  int gpu_idx = ChameleonNoise::GetNoiseInt(
+      ChameleonNoise::kSubsystemNavigator + 300, kGpuCount);
+  p.gpu_vendor = kGpus[gpu_idx].vendor;
+  p.gpu_renderer = kGpus[gpu_idx].renderer;
+
+  int cores_idx = ChameleonNoise::GetNoiseInt(
+      ChameleonNoise::kSubsystemNavigator + 301, kCoresCount);
+  p.cores = kCoresPool[cores_idx];
+
+  int mem_idx = ChameleonNoise::GetNoiseInt(
+      ChameleonNoise::kSubsystemNavigator + 302, kMemoryCount);
+  p.memory = kMemoryPool[mem_idx];
+
+  int tex_idx = ChameleonNoise::GetNoiseInt(
+      ChameleonNoise::kSubsystemNavigator + 303, kTextureCount);
+  p.max_texture = kTexturePool[tex_idx];
+
+  return p;
+}
 
 const HardwareProfile& GetSelectedProfile() {
-  int idx = ChameleonNoise::GetNoiseInt(
-      ChameleonNoise::kSubsystemNavigator + 300, kProfileCount);
-  return kProfiles[idx];
+  static HardwareProfile* profile = nullptr;
+  if (!profile) {
+    profile = new HardwareProfile(BuildProfile());
+  }
+  return *profile;
 }
 
