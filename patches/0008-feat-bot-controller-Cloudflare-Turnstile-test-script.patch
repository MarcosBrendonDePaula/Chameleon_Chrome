+"""Test Chameleon vs Cloudflare Turnstile on Berachain faucet."""
+from selenium import webdriver
+from selenium.webdriver.chrome.options import Options
+from selenium.webdriver.chrome.service import Service
+from selenium.webdriver.common.by import By
+from selenium.webdriver.support.ui import WebDriverWait
+from selenium.webdriver.support import expected_conditions as EC
+import time
+import random
+
+def log(msg):
+    print(msg, flush=True)
+
+seed = ''.join(random.choices('0123456789abcdef', k=32))
+profile_name = 'cf_test_' + ''.join(random.choices('abcdef', k=4))
+profile_dir = f"E:\\chameleon_profiles\\{profile_name}"
+
+log(f"=== CLOUDFLARE TURNSTILE TEST ===")
+log(f"Seed: {seed}")
+
+options = Options()
+options.binary_location = "E:\\CHAMALEON\\out\\Default\\chrome.exe"
+options.add_argument(f"--user-data-dir={profile_dir}")
+options.add_argument(f"--chameleon-seed={seed}")
+options.add_argument("--chameleon-locale=en-US,en")
+
+service = Service("E:\\CHAMALEON\\out\\Default\\chromedriver.exe")
+driver = webdriver.Chrome(service=service, options=options)
+
+# Check identity
+driver.get("about:blank")
+time.sleep(1)
+info = driver.execute_script("""
+    return {
+        webdriver: navigator.webdriver,
+        platform: navigator.platform,
+        cores: navigator.hardwareConcurrency
+    };
+""")
+log(f"webdriver={info['webdriver']} platform={info['platform']} cores={info['cores']}")
+
+# Go to faucet
+log("\nLoading Berachain faucet...")
+driver.get("https://bepolia.faucet.berachain.com/")
+time.sleep(5)
+log(f"Page loaded: {driver.title}")
+
+# Screenshot current state
+log("Waiting for Cloudflare Turnstile to appear...")
+time.sleep(5)
+
+# Try to find the Turnstile iframe
+try:
+    iframes = driver.find_elements(By.TAG_NAME, "iframe")
+    log(f"Found {len(iframes)} iframes")
+    for i, iframe in enumerate(iframes):
+        src = iframe.get_attribute("src") or ""
+        log(f"  iframe[{i}]: {src[:80]}")
+except Exception as e:
+    log(f"Error finding iframes: {e}")
+
+# Try to find and click the Turnstile checkbox
+log("\nTrying to interact with Turnstile...")
+try:
+    # Turnstile is inside an iframe
+    turnstile_iframe = None
+    for iframe in driver.find_elements(By.TAG_NAME, "iframe"):
+        src = iframe.get_attribute("src") or ""
+        if "turnstile" in src or "challenges.cloudflare.com" in src:
+            turnstile_iframe = iframe
+            break
+
+    if turnstile_iframe:
+        log("Found Turnstile iframe! Switching to it...")
+        driver.switch_to.frame(turnstile_iframe)
+        time.sleep(2)
+
+        # Try to find the checkbox
+        try:
+            checkbox = driver.find_element(By.CSS_SELECTOR, "input[type='checkbox']")
+            log("Found checkbox! Clicking...")
+            checkbox.click()
+            time.sleep(3)
+            log("Clicked!")
+        except:
+            # Try clicking the body of the iframe
+            try:
+                body = driver.find_element(By.TAG_NAME, "body")
+                body.click()
+                time.sleep(3)
+                log("Clicked iframe body")
+            except Exception as e:
+                log(f"Could not click: {e}")
+
+        driver.switch_to.default_content()
+    else:
+        log("Turnstile iframe not found. Checking page content...")
+        # Maybe it auto-solved or there's a different challenge
+        body_text = driver.execute_script("return document.body.innerText.slice(0, 500)")
+        log(f"Page text: {body_text[:300]}")
+
+except Exception as e:
+    log(f"Error: {e}")
+
+# Wait and check result
+log("\nWaiting 10s for verification...")
+time.sleep(10)
+
+# Check if we passed
+try:
+    body_text = driver.execute_script("return document.body.innerText.slice(0, 500)")
+    log(f"\nPage state: {body_text[:300]}")
+except:
+    pass
+
+log("\nBrowser open. Check manually. Ctrl+C to close.")
+try:
+    while True:
+        time.sleep(60)
+except KeyboardInterrupt:
+    pass
+driver.quit()
