+driver.get("https://bepolia.faucet.berachain.com/")
+
+# Wait for either challenge page or actual faucet page
+log("Waiting for page to load (up to 60s)...")
+for i in range(60):
+    time.sleep(1)
+    title = driver.title.lower()
+    try:
+        body = driver.execute_script("return document.body ? document.body.innerText.slice(0, 200) : ''")
