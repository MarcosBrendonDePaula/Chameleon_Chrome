+
+# Check for wallet input field
+try:
+    inputs = driver.find_elements(By.TAG_NAME, "input")
+    log(f"\nFound {len(inputs)} input fields")
+    for inp in inputs:
+        log(f"  input: type={inp.get_attribute('type')} name={inp.get_attribute('name')} placeholder={inp.get_attribute('placeholder')}")
+except:
+    pass
+
+# Check for Turnstile
+try:
+    turnstile = driver.find_element(By.CSS_SELECTOR, ".cf-turnstile")
+    log(f"\nTurnstile found: {turnstile.get_attribute('outerHTML')[:200]}")
+
+    # Check if token was generated
+    token_input = driver.find_element(By.CSS_SELECTOR, "input[name='cf-turnstile-response']")
+    token = token_input.get_attribute("value")
+    log(f"Turnstile token: {'YES (' + token[:30] + '...)' if token else 'EMPTY'}")
+except Exception as e:
+    log(f"\nNo Turnstile widget found: {e}")
+
+log("\nBrowser open. Ctrl+C to close.")
+try:
+    while True:
+        time.sleep(60)
+except KeyboardInterrupt:
+    pass
+driver.quit()
