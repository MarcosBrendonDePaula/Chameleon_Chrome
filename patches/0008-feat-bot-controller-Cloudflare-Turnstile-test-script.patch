diff --git a/bot_controller.py b/bot_controller.py
new file mode 100644
index 0000000000..bbd8e4219d
--- /dev/null
+++ b/bot_controller.py
@@ -0,0 +1,214 @@
+"""Chameleon Bot Controller - Control browser via command file."""
+from selenium import webdriver
+from selenium.webdriver.chrome.options import Options
+from selenium.webdriver.chrome.service import Service
+from selenium.webdriver.common.by import By
+from selenium.webdriver.common.keys import Keys
+from selenium.webdriver.support.ui import WebDriverWait
+from selenium.webdriver.support import expected_conditions as EC
+from selenium.webdriver.common.action_chains import ActionChains
+import time
+import random
+import json
+import os
+
+COMMAND_FILE = "E:\\CHAMALEON\\bot_cmd.json"
+RESULT_FILE = "E:\\CHAMALEON\\bot_result.txt"
+
+def log(msg):
+    print(msg, flush=True)
+    with open(RESULT_FILE, "a", encoding="utf-8") as f:
+        f.write(msg + "\n")
+
+def clear_results():
+    with open(RESULT_FILE, "w", encoding="utf-8") as f:
+        f.write("")
+
+def read_command():
+    if not os.path.exists(COMMAND_FILE):
+        return None
+    try:
+        with open(COMMAND_FILE, "r") as f:
+            cmd = json.load(f)
+        os.remove(COMMAND_FILE)
+        return cmd
+    except:
+        return None
+
+def execute_command(driver, cmd):
+    action = cmd.get("action", "")
+
+    if action == "goto":
+        url = cmd.get("url", "")
+        log(f"[CMD] Navigating to: {url}")
+        driver.get(url)
+        time.sleep(cmd.get("wait", 3))
+        log(f"[OK] Title: {driver.title}")
+
+    elif action == "click":
+        selector = cmd.get("selector", "")
+        log(f"[CMD] Clicking: {selector}")
+        try:
+            el = WebDriverWait(driver, 10).until(
+                EC.element_to_be_clickable((By.CSS_SELECTOR, selector))
+            )
+            el.click()
+            log("[OK] Clicked")
+        except Exception as e:
+            log(f"[ERR] {e}")
+
+    elif action == "type":
+        selector = cmd.get("selector", "")
+        text = cmd.get("text", "")
+        log(f"[CMD] Typing into: {selector}")
+        try:
+            el = WebDriverWait(driver, 10).until(
+                EC.presence_of_element_located((By.CSS_SELECTOR, selector))
+            )
+            el.clear()
+            el.send_keys(text)
+            log(f"[OK] Typed: {text[:50]}")
+        except Exception as e:
+            log(f"[ERR] {e}")
+
+    elif action == "js":
+        script = cmd.get("script", "")
+        log(f"[CMD] Running JS...")
+        try:
+            result = driver.execute_script(script)
+            log(f"[OK] Result: {result}")
+        except Exception as e:
+            log(f"[ERR] {e}")
+
+    elif action == "screenshot":
+        path = cmd.get("path", "E:\\CHAMALEON\\screenshot.png")
+        driver.save_screenshot(path)
+        log(f"[OK] Screenshot: {path}")
+
+    elif action == "turnstile":
+        log("[CMD] Solving Turnstile...")
+        try:
+            # Find iframe
+            iframes = driver.find_elements(By.CSS_SELECTOR, "iframe[src*='turnstile'], iframe[src*='challenges.cloudflare']")
+            if iframes:
+                log(f"[OK] Found {len(iframes)} Turnstile iframe(s)")
+                driver.switch_to.frame(iframes[0])
+                time.sleep(2)
+                try:
+                    cb = driver.find_element(By.CSS_SELECTOR, "input[type='checkbox']")
+                    cb.click()
+                    log("[OK] Clicked checkbox")
+                except:
+                    body = driver.find_element(By.TAG_NAME, "body")
+                    body.click()
+                    log("[OK] Clicked iframe body")
+                time.sleep(5)
+                driver.switch_to.default_content()
+            else:
+                log("[INFO] No Turnstile iframe found")
+
+            # Check token
+            time.sleep(3)
+            token = driver.execute_script("""
+                var input = document.querySelector("input[name='cf-turnstile-response']");
+                return input ? input.value : 'NOT FOUND';
+            """)
+            if token and len(token) > 10:
+                log(f"[OK] Token: {token[:60]}...")
+            else:
+                log(f"[INFO] Token: {token}")
+        except Exception as e:
+            log(f"[ERR] {e}")
+
+    elif action == "text":
+        log("[CMD] Getting page text...")
+        try:
+            text = driver.execute_script("return document.body.innerText.slice(0, 1000)")
+            log(f"[OK] {text[:500]}")
+        except Exception as e:
+            log(f"[ERR] {e}")
+
+    elif action == "html":
+        selector = cmd.get("selector", "body")
+        log(f"[CMD] Getting HTML of: {selector}")
+        try:
+            el = driver.find_element(By.CSS_SELECTOR, selector)
+            log(f"[OK] {el.get_attribute('outerHTML')[:500]}")
+        except Exception as e:
+            log(f"[ERR] {e}")
+
+    elif action == "elements":
+        selector = cmd.get("selector", "input")
+        log(f"[CMD] Finding elements: {selector}")
+        try:
+            els = driver.find_elements(By.CSS_SELECTOR, selector)
+            log(f"[OK] Found {len(els)} elements")
+            for i, el in enumerate(els[:10]):
+                tag = el.tag_name
+                eid = el.get_attribute("id") or ""
+                name = el.get_attribute("name") or ""
+                etype = el.get_attribute("type") or ""
+                text = el.text[:50] if el.text else ""
+                log(f"  [{i}] <{tag}> id={eid} name={name} type={etype} text={text}")
+        except Exception as e:
+            log(f"[ERR] {e}")
+
+    elif action == "submit":
+        selector = cmd.get("selector", "form")
+        log(f"[CMD] Submitting: {selector}")
+        try:
+            el = driver.find_element(By.CSS_SELECTOR, selector)
+            el.submit()
+            log("[OK] Submitted")
+        except Exception as e:
+            log(f"[ERR] {e}")
+
+    elif action == "wait":
+        secs = cmd.get("seconds", 5)
+        log(f"[CMD] Waiting {secs}s...")
+        time.sleep(secs)
+        log("[OK] Done")
+
+    elif action == "status":
+        log(f"[STATUS] URL: {driver.current_url}")
+        log(f"[STATUS] Title: {driver.title}")
+        cookies = driver.get_cookies()
+        log(f"[STATUS] Cookies: {len(cookies)}")
+
+    else:
+        log(f"[ERR] Unknown action: {action}")
+
+# Setup
+clear_results()
+log("=== CHAMELEON BOT CONTROLLER ===")
+log("Waiting for commands in bot_cmd.json")
+log("Actions: goto, click, type, js, screenshot, turnstile, text, html, elements, submit, wait, status\n")
+
+seed = ''.join(random.choices('0123456789abcdef', k=32))
+profile_dir = f"E:\\chameleon_profiles\\bot_{''.join(random.choices('abcdef', k=4))}"
+
+options = Options()
+options.binary_location = "E:\\CHAMALEON\\out\\Default\\chrome.exe"
+options.add_argument(f"--user-data-dir={profile_dir}")
+options.add_argument(f"--chameleon-seed={seed}")
+options.add_argument("--chameleon-locale=en-US,en")
+
+service = Service("E:\\CHAMALEON\\out\\Default\\chromedriver.exe")
+driver = webdriver.Chrome(service=service, options=options)
+
+log(f"Browser ready. webdriver={driver.execute_script('return navigator.webdriver')}")
+log("Drop commands into E:\\CHAMALEON\\bot_cmd.json\n")
+
+# Command loop
+try:
+    while True:
+        cmd = read_command()
+        if cmd:
+            execute_command(driver, cmd)
+            log("")
+        time.sleep(1)
+except KeyboardInterrupt:
+    pass
+
+driver.quit()
+log("Bot closed.")
