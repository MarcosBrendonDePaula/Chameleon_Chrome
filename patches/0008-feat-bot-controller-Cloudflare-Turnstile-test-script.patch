+"""Chameleon final test - cookies + proxy + fingerprint check."""
+from selenium import webdriver
+from selenium.webdriver.chrome.options import Options
+from selenium.webdriver.chrome.service import Service
+from chameleon_cookies import generate_cookies
+import time
+import random
+
+def log(msg):
+    print(msg, flush=True)
+
+seed = ''.join(random.choices('0123456789abcdef', k=32))
+profile_name = 'final_' + ''.join(random.choices('abcdef', k=5))
+profile_dir = f"E:\\chameleon_profiles\\{profile_name}"
+
+log(f"=== CHAMELEON FINAL TEST ===")
+log(f"Seed: {seed}")
+log(f"Profile: {profile_name}")
+log(f"Proxy: 151.245.244.140:50100")
+
+options = Options()
+options.binary_location = "E:\\CHAMALEON\\out\\Default\\chrome.exe"
+options.add_argument(f"--user-data-dir={profile_dir}")
+options.add_argument(f"--chameleon-seed={seed}")
+options.add_argument("--chameleon-locale=pt-BR,pt")
+options.add_argument("--proxy-server=http://151.245.244.140:50100")
+
+service = Service("E:\\CHAMALEON\\out\\Default\\chromedriver.exe")
+driver = webdriver.Chrome(service=service, options=options)
+
+# Cookie warmup
+log("\n--- Cookie Warmup ---")
+cookies = generate_cookies(seed)
+injected = 0
+domains = {}
+for c in cookies:
+    d = c["domain"].lstrip(".")
+    if d not in domains:
+        domains[d] = []
+    domains[d].append(c)
+
+for domain, dcookies in domains.items():
+    try:
+        driver.get(f"https://{domain}")
+        time.sleep(2)
+        for cookie in dcookies:
+            try:
+                sc = {"name": cookie["name"], "value": cookie["value"],
+                      "domain": cookie["domain"], "path": cookie.get("path", "/"),
+                      "secure": cookie.get("secure", False)}
+                if cookie.get("expiry") and cookie["expiry"] > 0:
+                    sc["expiry"] = cookie["expiry"]
+                driver.add_cookie(sc)
+                injected += 1
+            except:
+                pass
+    except:
+        pass
+
+log(f"Cookies: {injected}/{len(cookies)} injected")
+
+# Quick warmup
+for url in ["https://www.google.com", "https://www.youtube.com"]:
+    try:
+        driver.get(url)
+        time.sleep(2)
+    except:
+        pass
+
+# Checks
+driver.get("about:blank")
+time.sleep(1)
+info = driver.execute_script("""
+    var c=document.createElement('canvas');var g=c.getContext('webgl');
+    var d=g.getExtension('WEBGL_debug_renderer_info');
+    return {
+        webdriver: navigator.webdriver,
+        platform: navigator.platform,
+        cores: navigator.hardwareConcurrency,
+        mem: navigator.deviceMemory,
+        lang: navigator.language,
+        tz: Intl.DateTimeFormat().resolvedOptions().timeZone,
+        gpu: d ? g.getParameter(d.UNMASKED_RENDERER_WEBGL).slice(0,55) : 'N/A'
+    };
+""")
+log(f"\n--- Identity ---")
+for k, v in info.items():
+    log(f"  {k}: {v}")
+
+# Fingerprint
+log(f"\n--- Fingerprint.com ---")
+driver.get("https://fingerprint.com")
+time.sleep(20)
+
+try:
+    result = driver.execute_script("""
+        var id = document.querySelector('.VisitsHistorySection-module--visitorId--ffa06');
+        var score = document.querySelector('.SuspectScore-module--score--31a26');
+        return {
+            visitorId: id ? id.textContent.trim() : 'not found',
+            score: score ? score.textContent.trim() : 'not found'
+        };
+    """)
+    log(f"  Visitor ID: {result['visitorId']}")
+    log(f"  Suspect Score: {result['score']}")
+except Exception as e:
+    log(f"  Error: {e}")
+
+log("\nBrowser open. Ctrl+C to close.")
+try:
+    while True:
+        time.sleep(60)
+except KeyboardInterrupt:
+    pass
+driver.quit()
