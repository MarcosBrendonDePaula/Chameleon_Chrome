From 091a575d89fbab71a7af76a2a2fad57cb07cb28b Mon Sep 17 00:00:00 2001
From: Marcos <marcosbrendonaz@gmail.com>
Date: Mon, 23 Mar 2026 07:47:00 -0300
Subject: [PATCH 01/14] feat: allow off-store extension installation
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Chameleon: Always allow off-store extension installation by making
OffStoreInstallAllowedByPrefs return true unconditionally.

🤖 Generated with [Claude Code](https://claude.com/claude-code)

Co-Authored-By: Claude <noreply@anthropic.com>
---
 chrome/browser/download/download_crx_util.cc | 5 ++---
 1 file changed, 2 insertions(+), 3 deletions(-)

diff --git a/chrome/browser/download/download_crx_util.cc b/chrome/browser/download/download_crx_util.cc
index 0ea66af007..657026c530 100644
--- a/chrome/browser/download/download_crx_util.cc
+++ b/chrome/browser/download/download_crx_util.cc
@@ -85,9 +85,8 @@ std::unique_ptr<ExtensionInstallPrompt> CreateExtensionInstallPrompt(
 }  // namespace
 
 bool OffStoreInstallAllowedByPrefs(Profile* profile, const DownloadItem& item) {
-  return g_allow_offstore_install_for_testing ||
-         extensions::ExtensionManagementFactory::GetForBrowserContext(profile)
-             ->IsOffstoreInstallAllowed(item.GetURL(), item.GetReferrerUrl());
+  // Chameleon: Always allow off-store extension installation
+  return true;
 }
 
 // Tests can call this method to inject a mock ExtensionInstallPrompt
