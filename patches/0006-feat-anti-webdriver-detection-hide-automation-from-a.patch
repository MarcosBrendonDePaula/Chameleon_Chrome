diff --git a/test_dual_selenium.py b/test_dual_selenium.py
new file mode 100644
index 0000000000..460d956271
--- /dev/null
+++ b/test_dual_selenium.py
@@ -0,0 +1,98 @@
+from selenium import webdriver
+from selenium.webdriver.chrome.options import Options
+from selenium.webdriver.chrome.service import Service
+import time
+import random
+import threading
+
+def log(msg):
+    print(msg, flush=True)
+
+def run_profile(name, seed, proxy, port):
+    log(f"[{name}] Starting... seed={seed[:16]}... port={port}")
+    profile_dir = f"E:\\chameleon_profiles\\{name}"
+
+    options = Options()
+    options.binary_location = "E:\\CHAMALEON\\out\\Default\\chrome.exe"
+    options.add_argument(f"--user-data-dir={profile_dir}")
+    options.add_argument(f"--chameleon-seed={seed}")
+    options.add_argument("--chameleon-locale=pt-BR,pt")
+    if proxy:
+        options.add_argument(f"--proxy-server=http://{proxy}")
+
+    service = Service("E:\\CHAMALEON\\out\\Default\\chromedriver.exe", port=port)
+    driver = webdriver.Chrome(service=service, options=options)
+
+    # Checks
+    driver.get("about:blank")
+    time.sleep(1)
+    info = driver.execute_script("""
+        var c=document.createElement('canvas');var g=c.getContext('webgl');
+        var d=g.getExtension('WEBGL_debug_renderer_info');
+        return {
+            webdriver: navigator.webdriver,
+            cores: navigator.hardwareConcurrency,
+            mem: navigator.deviceMemory,
+            gpu: d ? g.getParameter(d.UNMASKED_RENDERER_WEBGL).slice(0,50) : 'N/A'
+        };
+    """)
+    log(f"[{name}] webdriver={info['webdriver']} cores={info['cores']} mem={info['mem']}")
+    log(f"[{name}] GPU: {info['gpu']}")
+
+    # Fingerprint
+    log(f"[{name}] Loading fingerprint.com...")
+    driver.get("https://fingerprint.com")
+    time.sleep(20)
+
+    try:
+        result = driver.execute_script("""
+            var text = document.body.innerText;
+            var idMatch = text.match(/visitor ID[\\s\\n]*([a-zA-Z0-9]+)/);
+            var scoreMatch = text.match(/Suspect Score[\\s\\n]*(\\d+)/);
+            return {
+                visitorId: idMatch ? idMatch[1] : 'not found',
+                score: scoreMatch ? scoreMatch[1] : 'not found'
+            };
+        """)
+        log(f"[{name}] Visitor ID: {result['visitorId']}")
+        log(f"[{name}] Score: {result['score']}")
+    except Exception as e:
+        log(f"[{name}] Error: {e}")
+
+    return driver
+
+seed1 = ''.join(random.choices('0123456789abcdef', k=32))
+seed2 = ''.join(random.choices('0123456789abcdef', k=32))
+
+log("=== DUAL SELENIUM TEST ===")
+
+results = {}
+
+def start_profile(name, seed, port):
+    results[name] = run_profile(name, seed, "2.56.249.17:50100", port)
+
+t1 = threading.Thread(target=start_profile, args=("perfil_A", seed1, 9515))
+t2 = threading.Thread(target=start_profile, args=("perfil_B", seed2, 9516))
+
+t1.start()
+time.sleep(5)
+t2.start()
+
+t1.join()
+t2.join()
+
+log("\n=== BOTH BROWSERS OPEN ===")
+log("Ctrl+C to close both.")
+
+try:
+    while True:
+        time.sleep(60)
+except KeyboardInterrupt:
+    pass
+
+for name, d in results.items():
+    try:
+        d.quit()
+    except:
+        pass
+log("Done!")
