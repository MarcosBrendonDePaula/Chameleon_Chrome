+"""
+Chameleon Cookie Warmup - Generates realistic synthetic cookies for new profiles.
+Usage:
+  - Standalone: python chameleon_cookies.py <profile_dir> [seed]
+  - As module: from chameleon_cookies import generate_cookies, inject_cookies
+"""
+
+import hashlib
+import time
+import math
+import json
+import os
+import sys
+
+
+def prng(seed_str, index):
+    """Deterministic PRNG based on seed string + index."""
+    h = hashlib.md5(f"{seed_str}:{index}".encode()).hexdigest()
+    return int(h[:8], 16) / 0xFFFFFFFF
+
+
+def prng_int(seed_str, index, max_val):
+    return int(prng(seed_str, index) * max_val)
+
+
+def prng_choice(seed_str, index, options):
+    return options[prng_int(seed_str, index, len(options))]
+
+
+def generate_ga_id(seed_str):
+    """Generate Google Analytics _ga cookie value."""
+    client_id = prng_int(seed_str, 100, 9999999999)
+    timestamp = int(time.time()) - prng_int(seed_str, 101, 86400 * 30)
+    return f"GA1.1.{client_id}.{timestamp}"
+
+
+def generate_gid(seed_str):
+    """Generate Google Analytics _gid cookie value."""
+    client_id = prng_int(seed_str, 110, 9999999999)
+    timestamp = int(time.time()) - prng_int(seed_str, 111, 86400)
+    return f"GA1.1.{client_id}.{timestamp}"
+
+
+def generate_fbp(seed_str):
+    """Generate Facebook _fbp cookie value."""
+    timestamp = int(time.time() * 1000) - prng_int(seed_str, 120, 86400000 * 7)
+    rand = prng_int(seed_str, 121, 9999999999)
+    return f"fb.1.{timestamp}.{rand}"
+
+
+def generate_nid(seed_str):
+    """Generate Google NID cookie (consent/preferences)."""
+    chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_"
+    length = 140 + prng_int(seed_str, 130, 40)
+    result = ""
+    for i in range(length):
+        result += chars[prng_int(seed_str, 131 + i, len(chars))]
+    return result
+
+
+def generate_cookies(seed_str):
+    """Generate a realistic set of cookies for a new browser profile."""
+    now = int(time.time())
+    far_future = now + 86400 * 365 * 2  # 2 years
+    near_future = now + 86400 * 30  # 30 days
+    mid_future = now + 86400 * 180  # 6 months
+
+    cookies = []
+
+    # === Google cookies ===
+    cookies.append({
+        "name": "NID",
+        "value": generate_nid(seed_str),
+        "domain": ".google.com",
+        "path": "/",
+        "secure": True,
+        "httpOnly": True,
+        "sameSite": "None",
+        "expiry": mid_future
+    })
+    cookies.append({
+        "name": "CONSENT",
+        "value": f"PENDING+{prng_int(seed_str, 200, 999)}",
+        "domain": ".google.com",
+        "path": "/",
+        "secure": True,
+        "httpOnly": False,
+        "expiry": far_future
+    })
+    cookies.append({
+        "name": "AEC",
+        "value": "AVYB7c" + ''.join([chr(65 + prng_int(seed_str, 210 + i, 26)) for i in range(30)]),
+        "domain": ".google.com",
+        "path": "/",
+        "secure": True,
+        "httpOnly": True,
+        "sameSite": "Lax",
+        "expiry": mid_future
+    })
+    cookies.append({
+        "name": "SOCS",
+        "value": "CAISHAgBEhJnd3NfMjAyNTA" + ''.join([chr(65 + prng_int(seed_str, 250 + i, 26)) for i in range(20)]),
+        "domain": ".google.com",
+        "path": "/",
+        "secure": True,
+        "httpOnly": False,
+        "sameSite": "Lax",
+        "expiry": mid_future
+    })
+
+    # === Google Analytics (common on many sites) ===
+    ga_domains = [".google.com", ".youtube.com", ".amazon.com.br", ".uol.com.br"]
+    for i, domain in enumerate(ga_domains):
+        cookies.append({
+            "name": "_ga",
+            "value": generate_ga_id(f"{seed_str}:{domain}"),
+            "domain": domain,
+            "path": "/",
+            "secure": False,
+            "httpOnly": False,
+            "expiry": far_future
+        })
+        cookies.append({
+            "name": "_gid",
+            "value": generate_gid(f"{seed_str}:{domain}"),
+            "domain": domain,
+            "path": "/",
+            "secure": False,
+            "httpOnly": False,
+            "expiry": near_future
+        })
+
+    # === YouTube cookies ===
+    cookies.append({
+        "name": "PREF",
+        "value": f"f6=40000000&tz=America%2FSao_Paulo&f7={prng_int(seed_str, 300, 100)}",
+        "domain": ".youtube.com",
+        "path": "/",
+        "secure": True,
+        "httpOnly": False,
+        "expiry": far_future
+    })
+    cookies.append({
+        "name": "VISITOR_INFO1_LIVE",
+        "value": ''.join([chr(65 + prng_int(seed_str, 310 + i, 26)) for i in range(11)]),
+        "domain": ".youtube.com",
+        "path": "/",
+        "secure": True,
+        "httpOnly": True,
+        "sameSite": "None",
+        "expiry": mid_future
+    })
+    cookies.append({
+        "name": "YSC",
+        "value": ''.join([chr(65 + prng_int(seed_str, 330 + i, 52)) for i in range(11)]),
+        "domain": ".youtube.com",
+        "path": "/",
+        "secure": True,
+        "httpOnly": True,
+        "sameSite": "None",
+        "expiry": 0  # session
+    })
+
+    # === Facebook pixel (common on many sites) ===
+    fb_domains = [".facebook.com", ".instagram.com"]
+    for i, domain in enumerate(fb_domains):
+        cookies.append({
+            "name": "_fbp",
+            "value": generate_fbp(f"{seed_str}:{domain}"),
+            "domain": domain,
+            "path": "/",
+            "secure": True,
+            "httpOnly": False,
+            "sameSite": "Lax",
+            "expiry": near_future + 86400 * 60
+        })
+
+    # === Cloudflare cookies (very common) ===
+    cf_domains = [".cloudflare.com"]
+    for domain in cf_domains:
+        cookies.append({
+            "name": "__cf_bm",
+            "value": ''.join([chr(97 + prng_int(seed_str, 400 + i, 26)) for i in range(40)]),
+            "domain": domain,
+            "path": "/",
+            "secure": True,
+            "httpOnly": True,
+            "sameSite": "None",
+            "expiry": now + 1800  # 30 min
+        })
+
+    # === GDPR consent cookies (common in Brazil) ===
+    cookies.append({
+        "name": "CookieConsent",
+        "value": "{stamp:%27" + ''.join([chr(97 + prng_int(seed_str, 500 + i, 26)) for i in range(20)]) + "%27%2Cnecessary:true%2Cpreferences:true%2Cstatistics:true%2Cmarketing:true}",
+        "domain": ".uol.com.br",
+        "path": "/",
+        "secure": True,
+        "httpOnly": False,
+        "expiry": far_future
+    })
+
+    # === Amazon cookies ===
+    session_id = f"{prng_int(seed_str, 600, 999)}-{prng_int(seed_str, 601, 9999999)}-{prng_int(seed_str, 602, 9999999)}"
+    cookies.append({
+        "name": "session-id",
+        "value": session_id,
+        "domain": ".amazon.com.br",
+        "path": "/",
+        "secure": True,
+        "httpOnly": False,
+        "expiry": far_future
+    })
+    cookies.append({
+        "name": "session-id-time",
+        "value": str(now - prng_int(seed_str, 610, 86400 * 7)),
+        "domain": ".amazon.com.br",
+        "path": "/",
+        "secure": True,
+        "httpOnly": False,
+        "expiry": far_future
+    })
+    cookies.append({
+        "name": "i18n-prefs",
+        "value": "BRL",
+        "domain": ".amazon.com.br",
+        "path": "/",
+        "secure": True,
+        "httpOnly": False,
+        "expiry": far_future
+    })
+
+    # === Microsoft / Bing ===
+    cookies.append({
+        "name": "MUID",
+        "value": ''.join([hex(prng_int(seed_str, 700 + i, 16))[2:].upper() for i in range(32)]),
+        "domain": ".bing.com",
+        "path": "/",
+        "secure": True,
+        "httpOnly": False,
+        "sameSite": "None",
+        "expiry": far_future
+    })
+
+    # === Generic tracker cookies ===
+    cookies.append({
+        "name": "_tt_enable_cookie",
+        "value": "1",
+        "domain": ".tiktok.com",
+        "path": "/",
+        "secure": True,
+        "httpOnly": False,
+        "sameSite": "None",
+        "expiry": mid_future
+    })
+
+    return cookies
+
+
+def inject_cookies(driver, seed_str):
+    """Inject synthetic cookies into a Selenium WebDriver session."""
+    cookies = generate_cookies(seed_str)
+
+    # Group cookies by domain
+    domains = {}
+    for c in cookies:
+        d = c["domain"].lstrip(".")
+        if d not in domains:
+            domains[d] = []
+        domains[d].append(c)
+
+    # Navigate to each domain and inject cookies
+    for domain, domain_cookies in domains.items():
+        try:
+            driver.get(f"https://{domain}")
+            import time
+            time.sleep(1)
+            for cookie in domain_cookies:
+                try:
+                    selenium_cookie = {
+                        "name": cookie["name"],
+                        "value": cookie["value"],
+                        "domain": cookie["domain"],
+                        "path": cookie.get("path", "/"),
+                        "secure": cookie.get("secure", False),
+                        "httpOnly": cookie.get("httpOnly", False),
+                    }
+                    if cookie.get("expiry") and cookie["expiry"] > 0:
+                        selenium_cookie["expiry"] = cookie["expiry"]
+                    if cookie.get("sameSite"):
+                        selenium_cookie["sameSite"] = cookie["sameSite"]
+                    driver.add_cookie(selenium_cookie)
+                except Exception as e:
+                    pass  # Some cookies may fail due to domain mismatch
+        except Exception:
+            pass  # Some domains may not load
+
+
+def save_cookies_json(seed_str, output_path):
+    """Save generated cookies as JSON file."""
+    cookies = generate_cookies(seed_str)
+    with open(output_path, "w") as f:
+        json.dump(cookies, f, indent=2)
+    return len(cookies)
+
+
+if __name__ == "__main__":
+    if len(sys.argv) < 2:
+        print("Usage: python chameleon_cookies.py <profile_dir> [seed]")
+        print("  Generates cookies.json in the profile directory.")
+        sys.exit(1)
+
+    profile_dir = sys.argv[1]
+
+    if len(sys.argv) >= 3:
+        seed = sys.argv[2]
+    else:
+        seed_file = os.path.join(profile_dir, "chameleon_seed.txt")
+        if os.path.exists(seed_file):
+            with open(seed_file) as f:
+                seed = f.read().strip()
+        else:
+            import random
+            seed = ''.join(random.choices('0123456789abcdef', k=32))
+
+    output = os.path.join(profile_dir, "chameleon_cookies.json")
+    count = save_cookies_json(seed, output)
+    print(f"Generated {count} cookies -> {output}")
