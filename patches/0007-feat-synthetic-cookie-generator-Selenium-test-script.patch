+from selenium import webdriver
+from selenium.webdriver.chrome.options import Options
+from selenium.webdriver.chrome.service import Service
+import time
+import random
+import string
+
+seed = ''.join(random.choices('0123456789abcdef', k=32))
+profile_name = 'selenium_' + ''.join(random.choices(string.ascii_lowercase, k=5))
+profile_dir = f"E:\\chameleon_profiles\\{profile_name}"
+
+print(f"Profile: {profile_name}")
+print(f"Seed: {seed}")
+
+options = Options()
+options.binary_location = "E:\\CHAMALEON\\out\\Default\\chrome.exe"
+options.add_argument(f"--user-data-dir={profile_dir}")
+options.add_argument(f"--chameleon-seed={seed}")
+options.add_argument("--chameleon-locale=pt-BR,pt")
+
+service = Service("E:\\CHAMALEON\\out\\Default\\chromedriver.exe")
+driver = webdriver.Chrome(service=service, options=options)
+
+# Teste 1: navigator.webdriver
+driver.get("about:blank")
+time.sleep(1)
+wd = driver.execute_script("return navigator.webdriver")
+print(f"\n=== WEBDRIVER CHECK ===")
+print(f"navigator.webdriver: {wd}")
+
+# Teste 2: cdc_ variables
+cdc = driver.execute_script("""
+    var found = [];
+    for (var key in window) {
+        if (key.indexOf('cdc_') !== -1 || key.indexOf('$cdc') !== -1) found.push(key);
+    }
+    return found;
+""")
+print(f"cdc_ variables found: {cdc}")
+
+# Teste 3: automation flags
+auto_check = driver.execute_script("""
+    return {
+        webdriver: navigator.webdriver,
+        languages: navigator.languages,
+        plugins: navigator.plugins.length,
+        platform: navigator.platform,
+        hardwareConcurrency: navigator.hardwareConcurrency,
+        deviceMemory: navigator.deviceMemory
+    }
+""")
+print(f"Automation check: {auto_check}")
+
+# Teste 4: fingerprint.com
+print(f"\n=== LOADING FINGERPRINT.COM ===")
+driver.get("https://fingerprint.com")
+time.sleep(15)
+
+title = driver.title
+print(f"Page title: {title}")
+
+# Tentar pegar o visitor ID e score
+try:
+    result = driver.execute_script("""
+        var text = document.body.innerText;
+        var idMatch = text.match(/visitor ID\\s*([a-zA-Z0-9]+)/);
+        var scoreMatch = text.match(/Suspect Score\\s*(\\d+)/);
+        return {
+            visitorId: idMatch ? idMatch[1] : 'not found',
+            score: scoreMatch ? scoreMatch[1] : 'not found'
+        };
+    """)
+    print(f"Visitor ID: {result['visitorId']}")
+    print(f"Suspect Score: {result['score']}")
+except Exception as e:
+    print(f"Error getting results: {e}")
+
+input("\nPress Enter to close browser...")
+driver.quit()
+print("Done!")
